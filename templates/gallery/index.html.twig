{% extends 'base.html.twig' %}

{% block title %}{{ meta_title }}{% endblock %}

{% block body %}

<twig:Banner
    title="Every frame tells a story"
    subtitle="A thousand memories written without words."
    :breadcrumbs="[
        { label: 'Home', url: path('home'), type: 'link' },
        { label: 'separator', type: 'separator' },
        { label: 'Gallery', type: 'current' }
    ]"
    id="gallery-title"
    variant="dark"
/>

<section
    class="main-section-page gallery-page gallery u-display-center"
    aria-labelledby="gallery-title"
>
    <div class="gallery__container section-centered">

        {# ---- Filters ---- #}
        <div class="gallery__filters">
            <button class="gallery__filter-btn js-filter-button active" data-filter="*">All</button>
            {% for speciality in specialities %}
                {% set specialityClass = speciality.name|lower|replace({' ': '-', '_': '-'})|trim %}
                <button class="gallery__filter-btn js-filter-button" data-filter=".{{ specialityClass }}">{{ speciality.name }}</button>
            {% endfor %}
        </div>

        {# ---- Grid ---- #}
        <div class="gallery__grid js-gallery-grid gallery-glightbox-isotope">
            {% for photo in photos %}
                {% set specialityClass = photo.speciality ? photo.speciality.name|lower|replace({' ': '-', '_': '-'})|trim : '' %}
                <div class="gallery__item js-gallery-item {{ specialityClass }} {{ loop.index > 12 ? 'is-hidden' }}">
                    <a
                        href="{{ photo.path | imagine_filter('gallery_thumb_desktop') }}"
                        class="gallery__link js-gallery-lightbox"
                        data-gallery="gallery-main"
                        data-description="<a class='gslide-photographer-link' href='{{ path('team_show', { slug: photo.photographer.slug }) }}' target='_blank' aria-label='View {{ photo.photographer.firstName }} {{ photo.photographer.lastName }} profile, opens in new tab'><span class='gslide-photographer-name'>{{ photo.photographer.firstName }} {{ photo.photographer.lastName }}</span>{% if photo.speciality %}<span class='gslide-separator'>  </span><span class='gslide-speciality'>{{ photo.speciality.name }}</span>{% endif %}</a>"|raw
                        aria-label="View photo by {{ photo.photographer.firstName }} {{ photo.photographer.lastName }}"
                    >
                        <figure class="gallery__figure">
                            <picture>
                                <source 
                                    media="(min-width: 1024px)" 
                                    srcset="{{ photo.path | imagine_filter('gallery_thumb_desktop') }} 1x"
                                >
                                <source 
                                    media="(max-width: 1023px)" 
                                    srcset="{{ photo.path | imagine_filter('gallery_thumb_mobile') }} 1x"
                                >
                                <img 
                                    src="{{ photo.path | imagine_filter('gallery_thumb_desktop') }}" 
                                    alt="{{ photo.altText }}" 
                                    class="gallery__image u-img-cover"
                                    loading="lazy"
                                >
                            </picture>
                            <div class="gallery__overlay" >
                                <p class="gallery__overlay-name">{{ photo.photographer.firstName }} {{ photo.photographer.lastName }}</p>
                                {% if photo.speciality %}
                                    <p class="gallery__overlay-speciality">{{ photo.speciality.name }}</p>
                                {% endif %}
                            </div>
                            </figure>
                    </a>
                </div>
            {% else %}
                <p class="gallery__empty">No photos to display yet.</p>
            {% endfor %}
        </div>

        <div class="gallery__actions">
            <button class="gallery__more js-gallery-more button button--accent button--medium">SEE MORE</button>
        </div>

    </div>
</section>

{% endblock %}
