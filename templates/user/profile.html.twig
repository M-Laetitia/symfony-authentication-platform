{% extends 'base.html.twig' %}

{% block title %}My profile{% endblock %}

{% block body_class %}page--profile{% endblock %}

{% block body %}

<twig:Banner
    title="My Profile"
    subtitle="A closer look at your account! "
    :breadcrumbs="[
        { label: 'Home', url: path('home'), type: 'link' },
        { label: 'separator', type: 'separator' },
        { label: 'Profile', type: 'current' }
    ]"
    variant="dark"
    id="blog-title"
/>


<section
    class="main-section-page profile account account--profile u-display-center"
    aria-labelledby="profile-title"
>
    <div class="profile__container account__container auth__container">

        <div class="profile__layout">

            <!-- LEFT PANEL -->
            <aside class="profile__panel profile__panel--left">

                <!-- Avatar -->
                <section class="profile-avatar" aria-labelledby="profile-avatar-title">
                    <p id="profile-avatar-title" class="visually-hidden">
                        Profile picture
                    </p>

                    <figure class="profile-avatar__media">
                        <img
                            src="{{ user.avatar ? asset('uploads/' ~ user.avatar.path) : 'media/images/avatar-profile.jpg' }}"
                            alt="Profile picture"
                            class="profile-avatar__image u-img-cover "
                        >
                    </figure>

                    {# Upload avatar #}
                    <div class="profile-avatar__avatar-form">
                             {{ form_start(formAvatar, {attr: {class: 'profile-avatar__form'}}) }}
                             {{ form_widget(formAvatar.avatar, {attr: {class: 'input input--dark'}}) }}
                             <div class="field-error register-form-error">
                               {{ form_errors(formAvatar.avatar) }}  
                             </div>
                             
                             <button type="submit" class="button button--large button--accent">
                                 Upload picture
                             </button>
                         {{ form_end(formAvatar) }}
                    </div>

                    {# Delete avatar #}
                    <div class="profile-avatar__avatar-delete">
                        {% if user.avatar %}
                        <form method="post" action="{{ path('app_profile_delete_avatar') }}" onsubmit="return confirm('Are you sure you want to delete your avatar?');">
                            <button type="submit" class="button button--large button--border-accent">
                                Delete Avatar
                            </button>
                        </form>
                    {% endif %}
                    </div>


                </section>

             
                <!-- Change password -->
                <section
                    class="profile-password"
                    aria-labelledby="profile-password-title"
                >
                    <p
                        id="profile-password-title"
                        class="profile__title profile-password__title"
                    >
                        Change your password
                    </p>

                    {{ form_start(formPassword, { attr: { class: 'profile-password__form' } }) }}

                    <div class="profile-password__group">
                        {{ form_widget(formPassword.currentPassword, {
                            attr: {
                                class: 'input input--dark',
                                id: 'current-password'
                            }
                        }) }}
                        <div class="field-error register-form-error">
                            {{ form_errors(formPassword.currentPassword) }}
                        </div>
                        
                    </div>

                    <div class="profile-password__group">
                        {{ form_widget(formPassword.newPassword.first, {
                            attr: {
                                class: 'input input--dark',
                                id: 'new-password'
                            }
                        }) }}
                        <div class="field-error register-form-error">
                           {{ form_errors(formPassword.newPassword.first) }} 
                        </div>
                        
                    </div>

                    <div class="profile-password__group">
                        {{ form_widget(formPassword.newPassword.second, {
                            attr: {
                                class: 'input input--dark',
                                id: 'confirm-password'
                            }
                        }) }}
                        <div class="field-error register-form-error">
                           {{ form_errors(formPassword.newPassword.second) }} 
                        </div>
                        
                    </div>

                    <button
                        type="submit"
                        class="button button--large button--accent profile-password__submit"
                    >
                        Change my password
                    </button>

                    {{ form_end(formPassword) }}
                </section>

            </aside>

            <!-- RIGHT PANEL -->
            <main class="profile__panel profile__panel--right">

                <!-- Account info -->
                <section
                    class="profile-info"
                    aria-labelledby="profile-info-title"
                >

                {{ form_start(profilInfoForm, {
                    attr: { class: 'profile-info__form' }
                }) }}
                
                <div class="profile-info__group">
                    {{ form_label(profilInfoForm.username, 'Username', {
                        label_attr: { class: 'profile__title profile-info__label' }
                    }) }}
                    {{ form_widget(profilInfoForm.username, {
                        attr: { class: 'input input--dark' }
                    }) }}
                    <div class="field-error register-form-error">
                        {{ form_errors(profilInfoForm.username) }}
                    </div>
                    
                </div>
                
                <div class="profile-info__group">
                    {{ form_label(profilInfoForm.email, 'Email address', {
                        label_attr: { class: 'profile__title profile-info__label' }
                    }) }}
                    {{ form_widget(profilInfoForm.email, {
                        attr: { class: 'input input--dark' }
                    }) }}
                    <div class="field-error register-form-error">
                        {{ form_errors(profilInfoForm.email) }}
                    </div>
                </div>

                <button
                    type="submit"
                    class="button button--large button--accent profile-info__submit"
                >
                    Update information
                </button>

                {{ form_end(profilInfoForm) }}
                </section>

                <!-- Delete account -->
                <section
                    class="profile-delete-account"
                    aria-labelledby="profile-delete-account-title"
                >
                    <p
                        id="profile-delete-account-title"
                        class="profile__title profile-delete-account__title"
                    >
                        Delete your account
                    </p>

                    <p class="profile-delete-account__text">
                        This will permanently deactivate your account and all
                        your activities from Mosaic.
                        <strong>This cannot be undone.</strong>
                    </p>

                    <button
                        type="button"
                        class="button button--large button--border-accent profile-delete-account__action"
                        id="delete-account-btn"
                    >
                        Delete my account
                    </button>
                </section>

                <!-- Delete account confirmation modal -->
                <div id="delete-account-modal" class="modal" role="dialog" aria-labelledby="modal-title" aria-hidden="true">
                    <div class="modal__overlay" id="modal-overlay"></div>
                    <div class="modal__content">
                        <div class="modal__header">
                            <h2 id="modal-title" class="modal__title">Confirm account deletion</h2>
                            <button type="button" class="modal__close" id="modal-close" aria-label="Close modal">
                                &times;
                            </button>
                        </div>
                        <div class="modal__body">
                            <p class="modal__body--warning">Are you absolutely sure you want to delete your account? This action is irreversible and will :</p>
                            <ul>
                                <li>Permanently deactivate your account</li>
                                <li>Remove your personal data (email, username, avatar)</li>
                                <li>Pseudonymize your content (messages, comments will remain visible but attributed to "Deleted User")</li>
                            </ul>
                            <p class="modal__body--undone"><strong>This cannot be undone.</strong></p>
                        </div>
                        <div class="modal__footer">
                            <button type="button" class="button button--medium  button--accent" id="modal-cancel">
                                Cancel
                            </button>
                            <form id="delete-account-form" method="POST" action="{{ path('account_delete') }}" style="display: inline;">
                                <button type="submit" class="button button--medium button--danger">
                                    Delete my account permanently
                                </button>
                            </form>
                        </div>
                    </div>
                </div>

            </main>

        </div>
    </div>
</section>


{% endblock %}
