{% extends 'base.html.twig' %}

{% block footer %}{% endblock %}

{% block title %}Log in{% endblock %}

{% block body_class %}page--account{% endblock %}

{% block body %}
<section class="auth account account--auth u-display-center" aria-labelledby="auth-title">
    <div class="auth__container account__container">

        <!-- Header -->
        <div class="auth__header">
            <h1 id="auth-title" class="auth__title">PROFILE</h1>

            <div class="auth__nav" role="tablist" aria-label="Account navigation">
                <a href="{{ path('app_login') }}"
                   class="auth__tab tab--active"
                   role="tab"
                   aria-selected="true">
                    Log in
                </a>
            
                <a href="{{ path('app_register') }}"
                   class="auth__tab"
                   role="tab"
                   aria-selected="false">
                    Register
                </a>
            </div>
        </div>

        <!-- Form wrapper -->
        <div class="auth__content">

            <form method="post" class="auth-form" novalidate>

                {% if error %}
                    <div class="field-error error__alert auth-form__alert auth-form__alert-emailVerified" role="alert">
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                {% if app.user %}
                    <div class="auth-form__info">
                        You are logged in as {{ app.user.userIdentifier }},
                        <a href="{{ path('app_logout') }}" class="auth-form__link">
                            Log out
                        </a>
                    </div>
                {% endif %}

                <fieldset class="auth-form__fieldset">
                    <legend class="visually-hidden">Login credentials</legend>

                    <!-- Email -->
                    <div class="auth-form__group">
                        <label for="username" class="auth-form__label sr-only">
                            Email
                        </label>
                        <input
                            type="email"
                            id="username"
                            placeholder="Email address"
                            name="_username"
                            class="auth-form__input input input--dark input--large "
                            value="{{ last_username }}"
                            autocomplete="email"
                            required
                            autofocus
                        >
                    </div>

                    <!-- Password -->
                    <div class="auth-form__group">
                        <label for="password" class="auth-form__label sr-only">
                            Password
                        </label>
                        <input
                            type="password"
                            id="password"
                            placeholder="Password"
                            name="_password"
                            class="auth-form__input input input--dark input--large "
                            autocomplete="current-password"
                            required
                        >
                    </div>

                    <input type="hidden"
                           name="_csrf_token"
                           value="{{ csrf_token('authenticate') }}">
                </fieldset>

                <!-- Options -->
                <div class="auth-form__options u-display-space-between">

                    <div class="auth-form__remember">
                        <input
                            type="checkbox"
                            id="_remember_me"
                            name="_remember_me"
                            class="auth-form__checkbox"
                        >
                        <label for="_remember_me">
                            Remember me
                        </label>
                    </div>

                    <a href="{{ path('app_forgot_password_request') }}"
                       class="auth-form__forgot">
                        Lost your password&nbsp;?
                    </a>
                </div>

                <!-- Submit -->
                <button type="submit" class="button button--large auth-form__submit button--accent">
                    Log in
                </button>

            </form>
        </div>

    </div>
</section>


{% endblock %}