{% extends 'base.html.twig' %}

{% block title %}Payment Success{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>

        .success-page {
            width: 100vw;
            max-width: 500px;
            background: var(--color-grey-900);
            border-radius: 12px;
            box-shadow: 0 4px 24px rgba(0,0,0,0.07);
            text-align: center;
            padding: 4em 1em 2em 1em;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            margin-bottom: 200px;
        }
        .success-page__icon {
            font-size: 3rem;
            margin-bottom: 1.5rem;
        }
        .success-page__title {
            font-size: 2.2rem;
            font-weight: 700;
            margin-bottom: 0.7em;
            color: var(--color-accent);
        }
        .success-page__desc {
            color: var(--color-white);
            margin-bottom: 2em;
            font-size:16px;
        }
        .success-page__button {
            display: inline-block;
            margin-top: 1em;
            padding: 0.75em 2em;
            background: var(--color-accent);
            color: #fff;
            border-radius: 6px;
            font-weight: 600;
            text-decoration: none;
            transition: background 0.2s;
            font-size: 1.1rem;
            box-shadow: 0 2px 8px rgba(46,125,50,0.08);
        }
        .success-page__button:hover {
            background: var(--color-accent);
        }
    </style>
{% endblock %}

{% block body %}
    <twig:Banner
        title="Payment Successful!"
        subtitle="Thank you for your order."
        :breadcrumbs="[
            {label: 'Home', url: path('home'), type: 'link'},
            {label: 'separator', type: 'separator' },
            {label: 'Success', type: 'current'}
        ]"
    />
    <div class="success-page">

        <h2 class="success-page__title">Thank you for your trust!</h2>
        <p class="success-page__desc">
            Your order <strong>#{{ orderId }}</strong> is confirmed.<br>
            We’re thrilled to help you capture your special moments.<br>
            Your photographer will contact you soon to discuss the details and make sure everything is perfect.<br>
            <br>
            <span style="color: #75d279; font-weight: 500;">Your invoice is on its way by email.</span>
        </p>
        {% if invoice %}
            <a class="success-page__button" href="{{ path('invoice_download', { id: invoice.id }) }}" target="_blank">
                Download my invoice
            </a>
        {% endif %}

        <div class="success-page__btn">
            <a href="{{path('home')}}"><button class="button button--medium button--accent">GO BACK HOME</button></a>

        </div>

    </div>
{% endblock %}