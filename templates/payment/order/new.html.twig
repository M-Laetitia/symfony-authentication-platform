
{% extends 'base.html.twig' %}

{% block title %}Create Service Order{% endblock %}

{% block body %}

<twig:Banner
    title="Create Service Order"
    subtitle="Finalize your agreement and proceed to secure payment"
    :breadcrumbs="[
        { label: 'Home', url: path('home'), type: 'link' },
        { label: 'separator', type: 'separator' },
        { label: 'Conversations', url: path('chat'), type: 'link' },
        { label: 'separator', type: 'separator' },
        { label: proposal.photographer.user.username, url: path('chat_conversation_show', {id: proposal.conversation.id}), type: 'link' },
        { label: 'separator', type: 'separator' },
        { label: 'New Order', type: 'current' }
    ]"
    variant="dark"
/>


<section class="order-create-page">
    <div class="order-create-page__container">

        <!-- Page Header -->
        <div class="order-create-page__header">
            <h2 class="order-create-page__title">Your Service Order</h2>
            <p class="order-create-page__subtitle">Review the proposal details and complete your order - you will be redirect to the payment page.</p>
        </div>

        <!-- Proposal Summary -->
        <div class="order-summary">
            <!-- Service Info -->
            <div class="order-summary__section">
                <div class="order-summary__section-title">Service Details</div>
                
                <div class="order-summary__item">
                    <span class="order-summary__label">Photographer</span>
                    <span class="order-summary__value">{{ proposal.photographer.firstName }} {{ proposal.photographer.lastName }}</span>
                </div>

                <div class="order-summary__item">
                    <span class="order-summary__label">Service Title</span>
                    <span class="order-summary__value">{{ proposal.title }}</span>
                </div>

                {% if proposal.speciality %}
                <div class="order-summary__item">
                    <span class="order-summary__label">Speciality</span>
                    <span class="order-summary__value">{{ proposal.speciality.name }}</span>
                </div>
                {% endif %}

                <div class="order-summary__item description-item">
                    <span class="order-summary__label">Service Description</span>
                    <span class="order-summary__value">{{ proposal.message }}</span>
                </div>
                
            </div>

            <!-- Dates & Location -->
            <div class="order-summary__section">
                <div class="order-summary__section-title">Schedule & Location</div>
                
                <div class="order-summary__grid">
                    {% if proposal.serviceDate %}
                    <div class="order-summary__item">
                        <span class="order-summary__label">Service Date</span>
                        <span class="order-summary__value">{{ proposal.serviceDate|date('d/m/Y') }}</span>
                    </div>
                    {% endif %}

                    {% if proposal.startAt %}
                    <div class="order-summary__item">
                        <span class="order-summary__label">Start Time</span>
                        <span class="order-summary__value">{{ proposal.startAt|date('H:i') }}</span>
                    </div>
                    {% endif %}

                    {% if proposal.endAt %}
                    <div class="order-summary__item">
                        <span class="order-summary__label">End Time</span>
                        <span class="order-summary__value">{{ proposal.endAt|date('H:i') }}</span>
                    </div>
                    {% endif %}

                    {% if proposal.location %}
                    <div class="order-summary__item">
                        <span class="order-summary__label">Location</span>
                        <span class="order-summary__value">{{ proposal.location }}</span>
                    </div>
                    {% endif %}
                </div>
            </div>

            <!-- Delivery Details -->
            <div class="order-summary__section">
                <div class="order-summary__section-title">Delivery Details</div>
                
                <div class="order-summary__grid">
                    {% if proposal.editedPhotoCount %}
                    <div class="order-summary__item">
                        <span class="order-summary__label">Edited Photos</span>
                        <span class="order-summary__value">{{ proposal.editedPhotoCount }}</span>
                    </div>
                    {% endif %}

                    {% if proposal.deliveryDelay %}
                    <div class="order-summary__item">
                        <span class="order-summary__label">Delivery (days)</span>
                        <span class="order-summary__value">{{ proposal.deliveryDelay }}</span>
                    </div>
                    {% endif %}
                </div>
            </div>

            <!-- Pricing Section -->
            <div class="order-summary__section order-summary__pricing">
                <div class="order-summary__price-row">
                    <span>Price (excl. tax)</span>
                    <span>€{{ proposal.priceExcluTax|number_format(2, '.', ',') }}</span>
                </div>
                <div class="order-summary__price-row">
                    <span>Tax ({{ (proposal.tax.rate * 100)|number_format(0) }}%)</span>
                    <span>€{{ (proposal.priceExcluTax * proposal.tax.rate)|number_format(2, '.', ',') }}</span>
                </div>
                <div class="order-summary__total-row">
                    <span>Total Amount</span>
                    <span>€{{ (proposal.priceExcluTax * (1 + proposal.tax.rate))|number_format(2, '.', ',') }}</span>
                </div>
            </div>
        </div>

        <!-- Order Form -->
        <div class="order-form">
            {{ form_start(form, {
                'attr': {
                    'class': 'form'
                }
            }) }}

            <!-- Terms Section -->
            <div class="order-form__section order-form__section--agreement">
                <div class="order-form__section-title">Agreement</div>
                <div class="form-group">
                    <div class="form-checkbox-group">
                        {{ form_widget(form.acceptTerms, {
                            'attr': {
                                'class': 'form-control'
                            }
                        }) }}
                        <label>
                            I have read and agree to the 
                            <a href="{{ path('legal_terms') }}" target="_blank">Terms & Conditions</a>, 
                            <a href="{{ path('legal_cgv') }}" target="_blank">Sales Conditions</a>, 
                            <a href="{{ path('legal_notice') }}" target="_blank">Legal Notice</a>, 
                            and <a href="{{ path('legal_privacy') }}" target="_blank">Privacy Policy & Cookies</a>.
                        </label>
                    </div>
                </div>
            </div>



            <!-- Notes Section -->
            <div class="order-form__section">
                <div class="order-form__section-title">Additional Notes (Optional)</div>
                <div class="form-group">
                    {{ form_label(form.note) }}
                    {{ form_widget(form.note, {
                        'attr': {
                            'class': 'form-control',
                            'placeholder': 'Add any special instructions or notes...'
                        }
                    }) }}
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="order-form__actions">
                <a href="{{ path('chat_conversation_show', {id: proposal.conversation.id}) }}" class="button button--black-variant button--medium">
                    Back to Conversation
                </a>
                <button type="submit" class="button button--medium btn-confirm">
                    Proceed to Payment
                </button>
            </div>

            {{ form_end(form) }}
        </div>

    </div>
</section>

{% endblock %}