{% extends 'base.html.twig' %}
{% block footer %}{% endblock %}
{% block title %}Register{% endblock %}
{% block body_class %}page--account{% endblock %}
{% block body %}
    {# {% for flash_error in app.flashes('verify_email_error') %}
        <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
    {% endfor %} #}


<section class="register account account--register u-display-center" aria-labelledby="register-title">
    <div class="register__container account__container">

        <!-- Header -->
        <div class="auth__header">
            <h1 id="auth-title" class="auth__title">PROFILE</h1>

            <div class="auth__nav" role="tablist" aria-label="Account navigation">
                <a href="{{ path('app_login') }}"
                   class="auth__tab "
                   role="tab"
                   aria-selected="false">
                    Log in
                </a>
            
                <a href="{{ path('app_register') }}"
                   class="auth__tab tab--active"
                   role="tab"
                   aria-selected="true">
                    Register
                </a>
            </div>
        </div>

        
        {{ form_errors(registrationForm) }}

        {{ form_start(registrationForm, {
            'attr': { 'class': 'auth-form', 'novalidate': 'novalidate' }
        }) }}
    
            <fieldset class="auth-form__fieldset">
                <legend class="visually-hidden">Register credentials</legend>
    
                <!-- Username -->
                <div class="auth-form__group">
                    {{ form_label(registrationForm.username, null, {'label_attr': {'class': 'auth-form__label sr-only'}}) }}
                    {{ form_widget(registrationForm.username, {
                        'attr': {
                            'class': 'auth-form__input input input--dark input--large'
                        }
                    }) }}
                    {# {% if registrationForm.vars.submitted %} #}
                        <div class="field-error register-form-error">
                        {{ form_errors(registrationForm.username) }}
                        </div>
                    {# {% endif %} #}
                </div>
    
                <!-- Email -->
                <div class="auth-form__group">
                    {{ form_label(registrationForm.email, null, {'label_attr': {'class': 'auth-form__label sr-only'}}) }}
                    {{ form_widget(registrationForm.email, {
                        'attr': {
                            'class': 'auth-form__input input input--dark input--large'
                        }
                    }) }}
                    <div class="field-error register-form-error">
                        {{ form_errors(registrationForm.email) }}
                    </div>
                </div>
    
                <!-- Password -->
                <div class="auth-form__group auth-form__group--password">
                    <div class="password-wrapper">
                        {{ form_label(registrationForm.plainPassword.first, 'Password', {'label_attr': {'class': 'auth-form__label sr-only'}}) }}
                        {{ form_widget(registrationForm.plainPassword.first, {
                            'attr': {
                                'class': 'auth-form__input input input--dark input--large'
    
                            }
                        }) }}
                        <span class="toggle-password">
                            <svg width="21" height="19" viewBox="0 0 21 19" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M19.4996 0.5L1.49959 18.5M1.04959 10.906C0.777595 10.533 0.641595 10.346 0.547595 9.986C0.484135 9.66544 0.484135 9.33556 0.547595 9.015C0.641595 8.654 0.777595 8.467 1.04959 8.095C2.53859 6.05 5.80259 2.5 10.4996 2.5C15.1966 2.5 18.4606 6.05 19.9496 8.094C20.2216 8.467 20.3576 8.654 20.4516 9.014C20.5151 9.33456 20.5151 9.66444 20.4516 9.985C20.3576 10.346 20.2216 10.533 19.9496 10.905C18.4606 12.95 15.1966 16.5 10.4996 16.5C5.80259 16.5 2.53859 12.95 1.04959 10.906ZM10.4996 11.5C11.03 11.5 11.5387 11.2893 11.9138 10.9142C12.2889 10.5391 12.4996 10.0304 12.4996 9.5C12.4996 8.96957 12.2889 8.46086 11.9138 8.08579C11.5387 7.71071 11.03 7.5 10.4996 7.5C9.96916 7.5 9.46045 7.71071 9.08538 8.08579C8.71031 8.46086 8.49959 8.96957 8.49959 9.5C8.49959 10.0304 8.71031 10.5391 9.08538 10.9142C9.46045 11.2893 9.96916 11.5 10.4996 11.5Z" stroke="#F2F2F2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </span>
                    </div>
                    <div class="field-error register-form-error">
                        {{ form_errors(registrationForm.plainPassword.first) }}
                    </div>

                    <div class="password-wrapper">
                        {{ form_label(registrationForm.plainPassword.second, 'Password', {'label_attr': {'class': 'auth-form__label sr-only'}}) }}
                        {{ form_widget(registrationForm.plainPassword.second, {
                            'attr': {
                                'class': 'auth-form__input input input--dark input--large'
                            }
                        }) }}
                        <span class="toggle-password">
                            <svg width="21" height="19" viewBox="0 0 21 19" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M19.4996 0.5L1.49959 18.5M1.04959 10.906C0.777595 10.533 0.641595 10.346 0.547595 9.986C0.484135 9.66544 0.484135 9.33556 0.547595 9.015C0.641595 8.654 0.777595 8.467 1.04959 8.095C2.53859 6.05 5.80259 2.5 10.4996 2.5C15.1966 2.5 18.4606 6.05 19.9496 8.094C20.2216 8.467 20.3576 8.654 20.4516 9.014C20.5151 9.33456 20.5151 9.66444 20.4516 9.985C20.3576 10.346 20.2216 10.533 19.9496 10.905C18.4606 12.95 15.1966 16.5 10.4996 16.5C5.80259 16.5 2.53859 12.95 1.04959 10.906ZM10.4996 11.5C11.03 11.5 11.5387 11.2893 11.9138 10.9142C12.2889 10.5391 12.4996 10.0304 12.4996 9.5C12.4996 8.96957 12.2889 8.46086 11.9138 8.08579C11.5387 7.71071 11.03 7.5 10.4996 7.5C9.96916 7.5 9.46045 7.71071 9.08538 8.08579C8.71031 8.46086 8.49959 8.96957 8.49959 9.5C8.49959 10.0304 8.71031 10.5391 9.08538 10.9142C9.46045 11.2893 9.96916 11.5 10.4996 11.5Z" stroke="#F2F2F2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </span>
                    </div>
                    <div class="field-error register-form-error">
                        {{ form_errors(registrationForm.plainPassword.second) }}
                    </div>

                    <div class="field-error register-form-error">
                        {{ form_errors(registrationForm.plainPassword) }}
                    </div>

                </div>
    
            </fieldset>
            
            <!-- Agree terms -->
            <div class="auth-form__group auth-form__group--checkbox">
                {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'auth-form__checkbox'}}) }}
                {{ form_label(registrationForm.agreeTerms, null, {'label_attr': {'class': 'auth-form__label'}}) }}
            </div>
            <div class="field-error register-form-error">
                {{ form_errors(registrationForm.agreeTerms) }}
            </div>
    
            <!-- Submit -->
            <button type="submit" class="button button--large auth-form__submit button--accent">
                Register
            </button>
    
        {{ form_end(registrationForm) }}

     
        </div>

    </div>
</section>


{% endblock %}
