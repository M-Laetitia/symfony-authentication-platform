{% extends 'base.html.twig' %}

{% block title %}{{ title }} | Blog{% endblock %}

{% block body %}

    <div class="category-form-wrapper">
        <h1>{{ title }}</h1>

        {{ form_start(form, {'attr': {'class': 'category-form'}}) }}
            {{ form_widget(form) }}
            
            <div class="form-actions">
                <button type="submit" class="button button--medium button--accent">
                    {% if category is defined and category.id %}
                        Update Category
                    {% else %}
                        Create Category
                    {% endif %}
                </button>
                <a href="{{ path('admin_blog_index') }}" class="button button--medium">Cancel</a>
            </div>
        {{ form_end(form) }}
    </div>


{% endblock %}
