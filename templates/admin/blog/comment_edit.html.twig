{% extends 'base.html.twig' %}

{% block title %}Edit Comment | Blog{% endblock %}

{% block body %}

<div class="admin-page admin-form admin-form--comment">
    <div class="admin-form__wrapper">
        <h1 class="admin-form__title">Edit Comment</h1>

        <div class="admin-form__info">
            <p class="admin-form__info-item">
                <strong>Article:</strong>
                <a href="{{ path('article_show', {'slug': comment.article.slug}) }}">
                    {{ comment.article.title }}
                </a>
            </p>

            <p class="admin-form__info-item">
                <strong>Author:</strong>
                {{ comment.authorName ?: comment.author.username }}
            </p>

            <p class="admin-form__info-item">
                <strong>Created:</strong>
                {{ comment.createdAt|date('Y-m-d H:i') }}
            </p>

            {% if comment.editedAt %}
                <p class="admin-form__info-item">
                    <strong>Last edited:</strong>
                    {{ comment.editedAt|date('Y-m-d H:i') }} by {{ comment.lastEditBy.username ? comment.lastEditBy.username : 'Unknown' }}
                </p>
            {% endif %}
        </div>

        {{ form_start(form, {'attr': {'class': 'admin-form__form'}}) }}
            {{ form_widget(form) }}
            
            {# Preserve the redirect_to parameter  #}
            {% if app.request.query.get('redirect_to') %}
                <input type="hidden" name="redirect_to" value="{{ app.request.query.get('redirect_to') }}" />
            {% endif %}
            
            <div class="admin-form__actions">
                <button type="submit" class="button button--medium button--accent">
                    Save Changes
                </button>
                <a href="{{ path('admin_blog_index') }}" class="button button--black-variant button--medium">
                    Cancel
                </a>
            </div>
        {{ form_end(form) }}
    </div>
</div>

{% endblock %}
