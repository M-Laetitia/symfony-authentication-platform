{% extends 'base.html.twig' %}

{% block title %} Blog | Dashboard{% endblock %}

{% block body %}

    {# list of articles #}
    <h1>Blog Management</h1>
    
    {# Statistics #}
    <div class="stats-container">
        <div class="stat-card">
            <div class="stat-value">{{ stats.total }}</div>
            <div class="stat-label">Total</div>
        </div>
        <div class="stat-card stat-published">
            <div class="stat-value">{{ stats.published }}</div>
            <div class="stat-label">Published</div>
        </div>
        <div class="stat-card stat-draft">
            <div class="stat-value">{{ stats.draft }}</div>
            <div class="stat-label">Draft</div>
        </div>
        <div class="stat-card stat-archived">
            <div class="stat-value">{{ stats.archived }}</div>
            <div class="stat-label">Archived</div>
        </div>
    </div>
    
    <section>
        {# add an article #}
        <a href="{{ path('article_new') }}" class="button button--medium button--accent">Add New Article</a>
        
        {# Filtres #}
        <div class="filters-container">
            {{ form_start(filterForm, {'attr': {'class': 'filters-form'}}) }}
                {{ form_row(filterForm.search, {'attr': {'style': 'flex: 1;'}, 'label': 'Search:'}) }}
                {{ form_row(filterForm.sortBy, {'label': 'Sort by:'}) }}
                {{ form_row(filterForm.status, {'label': 'Status:'}) }}
                {{ form_row(filterForm.featured, {'label': 'Featured:'}) }}
                {{ form_row(filterForm.category, {'label': 'Category:'}) }}
                
                <button type="submit" class="button button--small">Apply Filters</button>
                <a href="{{ path('admin_blog_index') }}" class="button button--small">Reset</a>
            {{ form_end(filterForm) }}
        </div>
        
        <table>
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Author</th>
                    <th>Created At</th>
                    <th>Category</th>
                    <th>Nb comments</th>
                    <th>Status</th>
                    <th>Featured</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for article in articles %}
                {# {{dump(article)}} #}
                    <tr>
                        <td>{{ article.title }}</td>
                        <td>{{ article.author.username }}</td>
                        <td>{{ article.createdAt|date('Y-m-d') }}</td>
                        <td>{{ article.category ? article.category.name : '-' }}</td>
                        <td>TEST: {{ article.comments.count() }} </td>
                        <td>{{ article.status.value }}</td>
                        <td>
                            <form method="POST" action="{{ path('article_toggle_featured', {'id': article.id}) }}" style="display:inline;">
                                <input type="checkbox" {% if article.isFeatured() %}checked{% endif %} onchange="this.form.submit()" class="featured-checkbox">
                            </form>
                        </td>
                        <td>
                            <a href="{{ path('article_show', {'slug': article.slug}) }}">View</a>
                            <a href="{{ path('article_edit', {'id': article.id}) }}">Edit</a>
                            
                            {# Dropdown pour changer le status #}
                            <form method="POST" action="{{ path('article_update_status', {'id': article.id}) }}" style="display:inline-flex; gap:0.5rem; align-items:center;">
                                <select name="status" class="status-select">
                                    <option value="published" {% if article.status.value == 'published' %}selected{% endif %}>Published</option>
                                    <option value="draft" {% if article.status.value == 'draft' %}selected{% endif %}>Draft</option>
                                    <option value="archived" {% if article.status.value == 'archived' %}selected{% endif %}>Archived</option>
                                </select>
                                <button type="submit" class="button button--small">Update</button>
                            </form>
                            
                            <button class="button button--small button--danger" onclick="document.getElementById('deleteModal{{ article.id }}').showModal()">Delete</button>
                            
                            {# Confirmation modale #}
                            <dialog id="deleteModal{{ article.id }}" class="admin-blog delete-modal">
                                <div class="modal-content">
                                    <h2>Confirm deletion</h2>
                                    <p>Are you sure you want to delete this article (<strong>{{ article.title }}</strong>) and all tis comments ? This action cannot be undone.</p>
                                    
                                    <div class="modal-actions">
                                        <form method="POST" action="{{ path('article_delete', {'id': article.id}) }}" style="display:inline;">
                                            <button type="submit" class="button button--small button--danger">DELETE</button>
                                        </form>
                                        <button type="button" class="button button--small" onclick="document.getElementById('deleteModal{{ article.id }}').close()">CANCEL</button>
                                    </div>
                                </div>
                            </dialog>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="8">No articles found.</td></tr>
                {% endfor %}
            </tbody>
        </table>
        
        {# Pagination #}
        <div class="pagination-container">
            {{ knp_pagination_render(articles) }}
        </div>

    </section>

    {# CATEGORIES MANAGEMENT #}
    <section class="categories-section">
        <h3>Categories Management</h3>
        
        <a href="{{ path('category_new') }}" class="button button--medium button--accent">Add New Category</a>
        
        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Slug</th>
                    <th>Description</th>
                    <th>Articles Count</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for category in categories %}
                    <tr>
                        <td><strong>{{ category.name }}</strong></td>
                        <td><code>{{ category.slug }}</code></td>
                        <td>{{ category.description ? category.description[:100] ~ '...' : '-' }}</td>
                        <td>
                            <span class="badge">{{ category.articles|length }}</span>
                        </td>
                        <td>
                            <a href="{{ path('category_edit', {'id': category.id}) }}" class="button button--small">Edit</a>
                            
                            <button class="button button--small button--danger" 
                                    onclick="document.getElementById('deleteCategoryModal{{ category.id }}').showModal()"
                                    {% if category.articles|length > 0 %}disabled{% endif %}>
                                Delete
                            </button>
                            
                            {# Delete Modal #}
                            <dialog id="deleteCategoryModal{{ category.id }}" class="admin-blog delete-modal">
                                <div class="modal-content">
                                    <h2>Confirm Category Deletion</h2>
                                    <p>Are you sure you want to delete the category <strong>{{ category.name }}</strong>?</p>
                                    
                                    <div class="modal-actions">
                                        <form method="POST" action="{{ path('category_delete', {'id': category.id}) }}" style="display:inline;">
                                            <button type="submit" class="button button--small button--danger">DELETE</button>
                                        </form>
                                        <button type="button" class="button button--small" onclick="document.getElementById('deleteCategoryModal{{ category.id }}').close()">CANCEL</button>
                                    </div>
                                </div>
                            </dialog>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="5">No categories found.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </section>

    {# TAGS MANAGEMENT #}
    <section class="tags-section">
        <h3>Tags Management</h3>
        
        <a href="{{ path('tag_new') }}" class="button button--medium button--accent">Add New Tag</a>
        
        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Slug</th>
                    <th>Articles Count</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for tag in tags %}
                    <tr>
                        <td><strong>{{ tag.name }}</strong></td>
                        <td><code>{{ tag.slug }}</code></td>
                        <td>
                            <span class="badge">{{ tag.articles|length }}</span>
                        </td>
                        <td>
                            <a href="{{ path('tag_edit', {'id': tag.id}) }}" class="button button--small">Edit</a>
                            
                            <button class="button button--small button--danger" 
                                    onclick="document.getElementById('deleteTagModal{{ tag.id }}').showModal()"
                                    {% if tag.articles|length > 0 %}disabled{% endif %}>
                                Delete
                            </button>
                            
                            {# Delete Modal #}
                            <dialog id="deleteTagModal{{ tag.id }}" class="admin-blog delete-modal">
                                <div class="modal-content">
                                    <h2>Confirm Tag Deletion</h2>
                                    <p>Are you sure you want to delete the tag <strong>{{ tag.name }}</strong>?</p>
                                    
                                    <div class="modal-actions">
                                        <form method="POST" action="{{ path('tag_delete', {'id': tag.id}) }}" style="display:inline;">
                                            <button type="submit" class="button button--small button--danger">DELETE</button>
                                        </form>
                                        <button type="button" class="button button--small" onclick="document.getElementById('deleteTagModal{{ tag.id }}').close()">CANCEL</button>
                                    </div>
                                </div>
                            </dialog>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="4">No tags found.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </section>

    {# COMMENTS MANAGEMENT #}
    <section class="comments-section">
        <h2>Comments Management</h2>
        
        <div class="comments-header">
            <span class="unapproved-count">
                <strong>Unapproved Messages: {{ unapprovedComments|length }}</strong>
            </span>
        </div>

        {% if unapprovedComments|length > 0 %}
            <div class="comments-table-wrapper">
                <table class="comments-table">
                    <thead>
                        <tr>
                            <th>Author</th>
                            <th>Article</th>
                            <th>Content</th>
                            <th>Created</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for comment in unapprovedComments %}
                        
                            <tr>
                                <td>
                                    <strong>{{ comment.authorName ?: comment.author.username }}</strong>
                                </td>
                                <td>
                                    <a href="{{ path('article_show', {'slug': comment.article.slug}) }}" target="_blank">
                                        {{ comment.article.title[:50] }}...
                                    </a>
                                </td>
                                <td>
                                    <div class="comment-preview">
                                        {{ comment.content[:100] }}...
                                    </div>
                                </td>
                                <td>{{ comment.createdAt|date('Y-m-d H:i') }}</td>
                                <td>
                                    <div class="comment-actions">
                                        {# Approve Button #}
                                        <form method="POST" action="{{ path('comment_approve', {'id': comment.id}) }}" style="display:inline;">
                                            <button type="submit" class="button button--small button--success">Approve</button>
                                        </form>

                                        {# Edit Button #}
                                        <a href="{{ path('comment_edit', {'id': comment.id}) }}" class="button button--small">Edit</a>

                                        {# Delete Button #}
                                        <button class="button button--small button--danger" 
                                                onclick="document.getElementById('deleteCommentModal{{ comment.id }}').showModal()">
                                            Delete
                                        </button>

                                        {# Delete Modal #}
                                        <dialog id="deleteCommentModal{{ comment.id }}" class="admin-blog delete-modal">
                                            <div class="modal-content">
                                                <h2>Confirm Comment Deletion</h2>
                                                <p>Are you sure you want to delete this comment?</p>
                                                <p class="comment-preview"><em>"{{ comment.content[:200] }}..."</em></p>
                                                
                                                <div class="modal-actions">
                                                    <form method="POST" action="{{ path('comment_delete', {'id': comment.id}) }}" style="display:inline;">
                                                        <button type="submit" class="button button--small button--danger">DELETE</button>
                                                    </form>
                                                    <button type="button" class="button button--small" onclick="document.getElementById('deleteCommentModal{{ comment.id }}').close()">CANCEL</button>
                                                </div>
                                            </div>
                                        </dialog>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <div class="no-comments-message">
                <p>✓ All comments have been approved!</p>
            </div>
        {% endif %}
    </section>
{% endblock %}
