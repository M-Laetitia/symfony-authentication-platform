<header class="page-hero{% if variant %} page-hero--{{ variant }}{% endif %} u-display-center">

    <div class="page-hero__container">
        <div class="page-hero__content">

            {% if subtitle is defined and subtitle %}
                <div class="page-hero__detail">
                    <p class="page-hero__subtitle">{{ subtitle }}</p>
                </div>
            {% endif %}

            <h1 {% if id is defined and id != '' %}id="{{ id }}"{% endif %} class="page-hero__title">
                {{ title }}
            </h1>

            {% if breadcrumbs is defined and breadcrumbs %}
                <nav class="breadcrumb" aria-label="breadcrumb">
                    <ul class="breadcrumb__list">
                        {% for crumb in breadcrumbs %}
                            <li class="breadcrumb__item breadcrumb__item--{{ crumb.type }}">

                                {% if crumb.type == 'separator' %}
                                    <span class="breadcrumb__separator" aria-hidden="true">›</span>

                                {% elseif crumb.url is defined %}
                                    <a href="{{ crumb.url }}" class="breadcrumb__link">
                                        {{ crumb.label }}
                                    </a>

                                {% else %}
                                    <span class="breadcrumb__current" aria-current="page">
                                        {{ crumb.label }}
                                    </span>
                                {% endif %}
                            </li>
                        {% endfor %}
                    </ul>
                </nav>
            {% endif %}

        </div>
    </div>

</header>