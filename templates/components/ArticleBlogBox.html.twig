 <!-- Article -->
 <article class="article-card">

    <!-- Media -->
    <div class="article-card__media">
        <time 
            class="article-card__date"
            datetime="{{ date|date('Y-m-d') }}"
        >
            {{ date }}
        </time>

        <a href="{{ path('article_show', {'slug': slug}) }}" class="article-card__media-link">
            <picture class="article-card__picture">
                <img
                    src="{{ asset('uploads/' ~ imagePath) }}"
                    alt="{{ alt is defined and alt != '' ? alt : title }}"
                    class="article-card__image u-img-cover"
                    loading="lazy"
                >
            </picture>
        </a>
    </div>

    <!-- Content -->
    <div class="article-card__content">
        <h4 class="article-card__title">
            <a href="{{ path('article_show', {'slug': slug}) }}" class="article-card__link">
                {{ title }}
            </a>
        </h4>

        <!-- Tags -->
        {% if tags is defined and tags is iterable and tags|length > 0 %}
        <ul class="article-card__tags" aria-label="Article tags">
            {% for tag in tags %}
                <li class="article-card__tag">
                    {{ tag }}
                </li>
            {% endfor %}
        </ul>
        {% endif %}

        <!-- Excerpt -->
        {% if excerpt is defined and excerpt is not empty %}
        <p class="article-card__excerpt">
            {{ excerpt }}
        </p>
        {% endif %}
    </div>

</article>
<!-- /Article -->