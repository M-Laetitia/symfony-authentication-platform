<a href="{{ path('team_show', { slug: slug }) }}"  aria-label="See {{name}}\'s profil">
    <div 
    class="section-photographs__item photograph-box"
    role="group"
    aria-labelledby="photographs-title"
    >

    <figure class="section-photographs__media">
        
            <img 
                src="{{ imageSrc }}" 
                alt="{{ name }} photography"
                class="section-photographs__image u-img-cover"
                loading="lazy"
                width="400"
                height="500"
            >
       
    </figure>

        <div class="section-photographs__infos">
            <p class="section-photographs__service">{{service}}</p>
            <h3 class="section-photographs__name">{{name}}</h3>
        </div>

</div> </a>