<div class="modal proposal-modal refuse" id="refuseModal">
    <div class="modal-backdrop"></div>

    <div class="modal-content">
        <h5 class="modal__title modal__title--danger" >Decline Proposal</h5>
        <p class="modal__description">Are you sure you want to decline this proposal?</p>

        <div class="modal__info-box modal__info-box--danger">
            <p><strong>Title:</strong> {{ proposal.title }}</p>
            <p><strong>Message:</strong> {{ proposal.message }}</p>
            <p><strong>Total price (incl. tax):</strong> €{{ (proposal.priceExcluTax * (1 + proposal.tax.rate))|number_format(2) }}</p>
        </div>

        <div class="modal__warning-box" >
            <p ><strong>This action cannot be undone.</strong> The proposal will be permanently declined.</p>
        </div>

        <div class="modal__actions">
            <button type="button" class="modal__btn modal__btn--secondary cancel-modal-btn button button--small button--black-variant">Cancel</button>

            <form method="post" action="{{ path('proposal_refuse', {'id': proposal.id}) }}" class="modal__form">
                <input type="hidden" name="_confirm_token" value="{{ csrf_token('confirm_refuse_' ~ proposal.id) }}">
                <input type="hidden" name="action" value="confirm">
                <button type="submit" class="modal__btn modal__btn--danger button button--small button--danger">Yes, Decline</button>
            </form>
        </div>
    </div>
</div>