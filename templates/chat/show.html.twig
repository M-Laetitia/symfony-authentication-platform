{% extends 'base.html.twig' %}


{% block title %}Conversation with {{ otherParticipant.username }} {% endblock %}



{% block body %}

{# <twig:Banner
title="My blabla page"
subtitle="Aut fuga culpa ab quibusdam"
variant="dark"
/> #}

<section id="conversation-page">
    <h1>Conversation avec {{ otherParticipant.username }}</h1>

    <ul>
        {% for msg in messages %}
            <li>
                <strong>{{ msg.sender.username }}</strong> :
                {{ msg.content }}
                <em>({{ msg.creationDate|date('H:i d/m/Y') }})</em>
        
                {# Bouton signaler uniquement pour photographe, si pas déjà reporté et pas son propre message #}
                {% if is_granted('ROLE_PHOTOGRAPH') and not msg.isReported and msg.sender.id != app.user.id %}
                    <button class="btn-report" data-message-id="{{ msg.id }}">Signaler</button>
                {% endif %}
        
                {# Afficher si le message a été reporté #}
                {% if msg.isReported %}
                    <div class="reported-message" style="color:red; font-style:italic; margin-top:5px;">
                        Message signalé{% if msg.reportReason %} : "{{ msg.reportReason }}"{% endif %}
                    </div>
                {% endif %}
            </li>
        {% else %}
            <li>Aucun message</li>
        {% endfor %}
        </ul>

        <div id="report-modal" class="modal" style="display:none;">
            <div class="modal-content">
                <span id="modal-close" style="float:right; cursor:pointer;">&times;</span>
                <h3>Signaler ce message</h3>
                {{ form_start(reportForm, {
                    'action': path('chat_message_report'),
                    'method': 'POST',
                    'attr': {'id': 'report-form'}
                }) }}
                    {{ form_widget(reportForm.reason) }}
                    <input type="hidden" name="messageId" id="report-message-id" value="">
                    <button type="submit">Envoyer</button>
                {{ form_end(reportForm) }}
            </div>
        </div>

        {% if not conversation.isFrozen or is_granted('ROLE_PHOTOGRAPH') %}
            {{ form_start(form, {'attr': {'id': 'message-form'}}) }}
            {{ form_widget(form.content, {'attr': {'id': 'message-input', 'placeholder': 'Écrire un message...'}}) }}
            <button type="submit">Envoyer</button>
            {{ form_end(form) }}
        {% else %}
            <div class="alert alert-danger">
                Votre message a été signalé. Vous ne pouvez plus envoyer de message
                en attente d'une vérification par l’administrateur.
            </div>
        {% endif %}
</section>






{% endblock %}