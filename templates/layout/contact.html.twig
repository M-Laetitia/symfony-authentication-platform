<section class="section section-contact scroll-text-section" aria-labelledby="contact-title">

    <div class="bg-text--scroll bg-text--contact" aria-hidden="true">
        <div class="bg-text__track">
            <span>CONTACT US</span>
            <span>CONTACT US</span>
            <span>CONTACT US</span>
            <span>CONTACT US</span>
        </div>
    </div>

    <div class="contact__container scroll-text-section__content">

        <!-- LEFT : CONTACT FORM -->
        <div class="contact__form-wrapper">
            <header class="contact__header">
                <h2 id="contact-title" class="contact__title">Contact Us</h2>
                <p class="contact__intro">
                    Get in touch to discuss a project, ask a question, or plan your next photoshoot.
                </p>
            </header>

            {{ form_start(contactForm, {'attr': {'class': 'contact__form'}}) }}

            <div class="contact__fields">
            
                <div class="contact__field">
                    {{ form_label(contactForm.name, 'Name', {'label_attr': {'class': 'contact__label sr-only'}}) }}
                    {{ form_widget(contactForm.name, {
                        'attr': {
                            'id': 'contact-name',
                            'class': 'contact__input input input--line',
                        }
                    }) }}
                    <div class="field-error register-form-error">
                        {{ form_errors(contactForm.name) }}
                    </div>
                </div>
            
                <div class="contact__field">
                    {{ form_label(contactForm.emailFrom, 'Email address', {'label_attr': {'class': 'contact__label sr-only'}}) }}
                    {{ form_widget(contactForm.emailFrom, {
                        'attr': {
                            'id': 'contact-email',
                            'class': 'contact__input input input--line',
                        }
                    }) }}
                    <div class="field-error register-form-error">
                        {{ form_errors(contactForm.emailFrom) }}
                    </div>
                </div>
            
                <div class="contact__field">
                    {{ form_label(contactForm.subject, 'Subject', {'label_attr': {'class': 'contact__label sr-only'}}) }}
                    {{ form_widget(contactForm.subject, {
                        'attr': {
                            'id': 'contact-subject',
                            'class': 'contact__input input input--line',
                        }
                    }) }}
                    <div class="field-error register-form-error">
                        {{ form_errors(contactForm.subject) }}
                    </div>
                </div>
            
                <div class="contact__field">
                    {{ form_label(contactForm.message, 'Message', {'label_attr': {'class': 'contact__label sr-only'}}) }}
                    {{ form_widget(contactForm.message, {
                        'attr': {
                            'id': 'contact-message',
                            'class': 'contact__textarea input input--textarea input--line',
                            'rows': 6
                        }
                    }) }}
                    <div class="field-error register-form-error">
                        {{ form_errors(contactForm.message) }}
                    </div>
                </div>
            
            </div>
            
            <div class="contact__consent terms--checkbox">
                {{ form_widget(contactForm.agreeTerms, {
                    'attr': {
                        'id': 'contact-terms',
                        'class': 'contact__checkbox'
                    }
                }) }}
                {{ form_label(contactForm.agreeTerms, '<p>I agree to the collection and use of my personal data in accordance with the <a href="#">Privacy Policy</a>.</p>', {
                    'label_html': true,
                    'label_attr': {'class': 'contact__checkbox-label'}
                }) }}
                <div class="field-error register-form-error">
                    {{ form_errors(contactForm.agreeTerms) }}
                </div>
            </div>
            
            <button type="submit" class="contact__submit button button--large button--accent">
                Send
            </button>
            
            {{ form_end(contactForm) }}
        </div>

        <!-- RIGHT : CONTACT DETAILS -->
        <div class="contact__info">
            <header class="contact__header">
                <h3 class="contact__title">Detail Information</h3>
                <p class="contact__intro">
                    All the information you need to reach us and start your photography project.
                </p>
            </header>

            <address class="contact__details">

                <a href="tel:+33102030405" class="contact__detail icon-box__container">
                    <div class="contact__icon">
                        <twig:IconBox 
                            svg='{{ include("components/icons/phone.html.twig") }}'
                        />
                    </div>

                    <div class="contact__detail-content">
                        <p class="contact__detail-label">Phone number</p>
                        <span class="contact__detail-link">
                            01 02 03 04 05
                        </span>
                    </div>
                </a>

                <a href="mailto:contact@mosaic.com" class="contact__detail icon-box__container">
                    <div class="contact__iconicon-box">
                        <twig:IconBox 
                            svg='{{ include("components/icons/contact.html.twig") }}'
                        />
                    </div>

                    <div class="contact__detail-content">
                        <p class="contact__detail-label">Email address</p>
                        <span class="contact__detail-link">
                            contact@mosaic.com
                        </span>
                    </div>
                </a>
                
                <a
                    href="https://www.google.com/maps?q=12+rue+des+Arts+67200+Strasbourg"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="contact__detail icon-box__container"
                >
                    <div class="contact__icon">
                        <twig:IconBox 
                            svg='{{ include("components/icons/map.html.twig") }}'
                        />
                    </div>

                    <div class="contact__detail-content">
                        <p class="contact__detail-label">Address</p>
                        <span class="contact__detail-link">
                            12 rue des Arts 67200 Strasbourg
                        </span>
                    </div>
                </a>
               
            </address>
        </div>

    </div>
</section>