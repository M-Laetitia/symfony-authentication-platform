<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Welcome!{% endblock %}</title>

        {# {% block preload %}{% endblock %} #}

        <link rel="icon" type="image/x-icon" href="{{ asset('media/favicon/favicon.ico') }}">
        <link rel="icon" type="image/png" sizes="32x32" href="{{ asset('media/favibon/favicon-96x96.png') }}">
        <link rel="apple-touch-icon" href="{{ asset('media/favicon/apple-touch-icon.png') }}">

         {# Meta description #}
        <meta name="description" content="{% block meta_description %}{{ meta_description|default('Default meta description') }}{% endblock %}">

        {# Meta robots #}
        <meta name="robots" content="{% block meta_robots %}{{ meta_robots|default('index, follow') }}{% endblock %}">
        
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        
        <script id="Cookiebot" src="https://consent.cookiebot.com/uc.js" data-cbid="b85e243f-decd-4396-8045-5dbf0e27e579" data-blockingmode="auto" type="text/javascript"></script>

        
        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
        {% endblock %}

        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
            {# {% block importmap %}{{ importmap('app') }}{% endblock %} #}
        {% endblock %}
    </head>
    
        {% block navbar %}
            {% include 'layout/navbar.html.twig' %}
        {% endblock %}

    <body class="{% block body_class %}{% endblock %}">
        <div class="page-wrapper">
    
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    {% if label == 'success' and message.type is defined and message.type == 'registration' %}
                        <div class="flash-message alert alert-{{ label }}">
                            {{ message.text|nl2br }}
                            <button type="button" class="flash-close" aria-label="Close">&times;</button>
                        </div>
                    {% else %}
                        <div class="flash-message alert alert-{{ label }}">
                            {{ message|nl2br }}
                        </div>
                    {% endif %}
                {% endfor %}
            {% endfor %}
    
            <main class="content">
                {% block body %}{% endblock %}

            </main>
    
            {% block footer %}
                {% include 'layout/footer.html.twig' %}
            {% endblock %}

        </div>
    </body>

    
    <!-- Overlay -->
    <div class="side-panel__overlay"></div>

    <!-- Scroll to Top Button -->
    <button id="scrollTopBtn" class="scroll-top-btn" aria-label="Scroll back to top">
        <svg width="16" height="10" viewBox="0 0 16 10" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M1 9L8 2L15 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
    </button>

    <!-- Aside -->
    <aside
        id="side-panel"
        class="side-panel"
        aria-hidden="true"
    >

        <div class="side-panel__content">

            <figure class="side-panel__figure">
                <img
                    src="{{ asset('media/mosaic-polaroids.webp') | imagine_filter('about_image_mobile') }}"
                    alt="MOSAIC Photography Studio"
                    class="side-panel__image u-img-cover"
                    width="400"
                    height="300"
                    loading="lazy"
                >
            </figure>

            <div class="side-panel__body">
                <p class="side-panel__brand">MOSAIC</p>
                <p class="side-panel__description">
                    Based in <strong>Strasbourg</strong>, MOSAIC is a <em>photography agency</em> dedicated to capturing the depth of human stories.
                    From <strong>portraits & lifestyle</strong> to <strong>weddings</strong>, <strong>fashion editorials</strong> and <em>documentary reportage</em> -
                    we craft images that endure. Each project is an encounter, each frame a commitment to <em>authenticity and intention</em>.
                </p>
            </div>

            <div class="side-panel__social">
                <a href="#" class="side-panel__social-link" aria-label="Facebook" rel="noopener noreferrer">
                    {% include 'components/icons/facebook.html.twig' %}
                </a>
                <a href="#" class="side-panel__social-link" aria-label="Instagram" rel="noopener noreferrer">
                    {% include 'components/icons/instagram.html.twig' %}
                </a>
                <a href="#" class="side-panel__social-link twitter" aria-label="Twitter" rel="noopener noreferrer">
                    {% include 'components/icons/twitter2.html.twig' %}
                </a>
            </div>

        </div>
    </aside>

</html>
