{% extends 'base.html.twig' %}

{% block title %}Studio Dashboard - {{ photographer.user.firstName }} {{ photographer.user.lastName }}{% endblock %}

{% block body %}

<twig:Banner
    title="Studio Dashboard"
    subtitle="Manage your photography studio"
    :breadcrumbs="[
        { label: 'Home', url: path('home'), type: 'link' },
        { label: 'separator', type: 'separator' },
        { label: 'Dashboard', type: 'current' }
    ]"
    variant="dark"
    id="dashboard-title"
/>

<section class="main-section-page dashboard photographer u-display-center" aria-labelledby="dashboard-title">
    <div class="dashboard__container section-centered">

        <h2 class="dashboard__title">
            Welcome, {{ photographer.firstName }}!
        </h2>

        <div class="dashboard__content">

            <!-- Profile Section -->
            <div class="dashboard__card">
                <h3 class="dashboard__card-title">Profile Settings</h3>
                <p class="dashboard__card-description">Manage your photographer profile and information</p>
                <a href="{{ path('photographer_dashboard_profile_edit', { slug: photographer.slug }) }}" class="button button--accent button--small">Edit Profile</a>
            </div>

            <!-- Galleries Section -->
            <div class="dashboard__card">
                <h3 class="dashboard__card-title">My Galleries</h3>
                <p class="dashboard__card-description">Create and manage your portfolio galleries</p>
                <a href="{{ path('photographer_gallery_index', { slug: photographer.slug }) }}" class="button button--accent button--small">Manage Galleries</a>
            </div>

            <!-- Services Section -->
            <div class="dashboard__card">
                <h3 class="dashboard__card-title">Pricing Plans</h3>
                <p class="dashboard__card-description">Create and manage your service pricing plans (Basic, Standard, Premium)</p>
                <a href="{{ path('photographer_dashboard_pricing_plans_index', { slug: photographer.slug }) }}" class="button button--accent button--small">Manage Pricing Plans</a>
            </div>

            <!-- Orders Section -->
            <div class="dashboard__card">
                <h3 class="dashboard__card-title">Service Proposals & Orders</h3>
                <p class="dashboard__card-description">
                    Review incoming proposals, monitor payments, and manage all customer orders from one place.
                </p>
                <a href="{{ path('admin_orders_index') }}" class="button button--accent button--small">
                    SEE DASHBOARD
                </a>
            </div>
        </div>

    </div>
</section>

{% endblock %}
