{% extends 'base.html.twig' %}

{% block title %}Add Photo - {{ photographer.user.firstName }} {{ photographer.user.lastName }}{% endblock %}

{% block body %}

<twig:Banner
    title="Add Photo to {{ gallery.name }}"
    subtitle="Upload a new photo to your gallery"
    :breadcrumbs="[
        { label: 'Home', url: path('home'), type: 'link' },
        { label: 'separator', type: 'separator' },
        { label: 'Dashboard', url: path('photographer_dashboard_index', { slug: photographer.slug }), type: 'link' },
        { label: 'separator', type: 'separator' },
        { label: 'Galleries', url: path('photographer_gallery_index', { slug: photographer.slug }), type: 'link' },
        { label: 'separator', type: 'separator' },
        { label: gallery.name, url: path('photographer_gallery_edit', { slug: photographer.slug, galleryId: gallery.id }), type: 'link' },
        { label: 'separator', type: 'separator' },
        { label: 'Add Photo', type: 'current' }
    ]"
    variant="dark"
/>

<section class="main-section-page media-add u-display-center">
    <div class="media-add__container section-centered" style="max-width: 800px;">

        <h2 class="media-add__title">Add Photo to {{ gallery.name }}</h2>

        <div class="media-add__recommendations">
            <h3>Recommendations</h3>
            <div class="media-add__recommendations-content">
                <p><strong>Recommended sizes:</strong></p>
                <ul>
                    <li>Portrait: 800×1200px (max 1800px width)</li>
                    <li>Landscape: 1600×900px (max 1800px width)</li>
                </ul>
                <p>Max size 4MB</p>
                <p><strong>Accepted formats:</strong> WebP, PNG, JPEG</p>
            </div>
        </div>

        {{ form_start(form, { 'attr': { 'class': 'media-form', 'enctype': 'multipart/form-data' } }) }}
            
            <div class="form-group">
                {{ form_label(form.media) }}
                {{ form_widget(form.media, { 'attr': { 'class': 'form-control' } }) }}
                {{ form_errors(form.media) }}
            </div>

            <div class="form-group">
                {{ form_label(form.altText) }}
                {{ form_widget(form.altText, { 'attr': { 'class': 'form-control' } }) }}
                <small class="form-help">This is important for accessibility and SEO. Be descriptive about the content.</small>
                {{ form_errors(form.altText) }}
            </div>

            <div class="form-group">
                {{ form_label(form.caption) }}
                {{ form_widget(form.caption, { 'attr': { 'class': 'form-control' } }) }}
                {{ form_errors(form.caption) }}
            </div>

            <div class="form-group form-group--checkbox">
                {{ form_widget(form.featured) }}
                {{ form_label(form.featured) }}
                {{ form_errors(form.featured) }}
            </div>

            <div class="form-actions">
                <button type="submit" class="button button--accent button--medium">Upload Photo</button>
                <a href="{{ path('photographer_gallery_edit', { slug: photographer.slug, galleryId: gallery.id }) }}" class="button button--black-variant button--medium">Cancel</a>
            </div>
        {{ form_end(form) }}

    </div>
</section>



{% endblock %}
