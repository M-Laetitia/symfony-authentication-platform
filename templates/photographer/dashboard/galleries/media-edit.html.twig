{% extends 'base.html.twig' %}

{% block title %}Edit Photo - {{ photographer.user.firstName }} {{ photographer.user.lastName }}{% endblock %}

{% block body %}

<twig:Banner
    title="Edit Photo"
    subtitle="Update photo details and manage display options"
    :breadcrumbs="[
        { label: 'Home', url: path('home'), type: 'link' },
        { label: 'separator', type: 'separator' },
        { label: 'Dashboard', url: path('photographer_dashboard_index', { slug: photographer.slug }), type: 'link' },
        { label: 'separator', type: 'separator' },
        { label: 'Galleries', url: path('photographer_gallery_index', { slug: photographer.slug }), type: 'link' },
        { label: 'separator', type: 'separator' },
        { label: gallery.name, url: path('photographer_gallery_edit', { slug: photographer.slug, galleryId: gallery.id }), type: 'link' },
        { label: 'separator', type: 'separator' },
        { label: 'Edit Photo', type: 'current' }
    ]"
    variant="dark"
/>

<section class="main-section-page media-edit u-display-center">
    <div class="media-edit__container section-centered">

        <div class="media-edit__layout">
            <!-- Image Preview -->
            <div class="media-edit__preview">
                <img 
                    src="{{ media.path | imagine_filter('gallery_thumb_edit') }}" 
                    alt="{{ media.altText }}"
                    class="media-edit__image"
                    loading="lazy"
                >
            </div>

            <!-- Edit Form -->
            <div class="media-edit__form-wrapper">
                <h2 class="media-edit__title">Edit Photo Details</h2>

                <form method="POST" class="media-form">
                    
                    <div class="form-group">
                        <label for="altText" class="form-label">Image Description (Alt Text)*</label>
                        <textarea 
                            id="altText" 
                            name="altText" 
                            class="form-control" 
                            rows="3"
                            required
                        >{{ media.altText }}</textarea>
                        <small class="form-help">Important for accessibility and SEO</small>
                    </div>

                    <div class="form-group">
                        <label for="caption" class="form-label">Caption (Optional)</label>
                        <textarea 
                            id="caption" 
                            name="caption" 
                            class="form-control" 
                            rows="2"
                        >{{ media.caption ?? '' }}</textarea>
                    </div>

                    <div class="form-group form-group--checkbox">
                        <input 
                            type="checkbox" 
                            id="isFeatured" 
                            name="isFeatured"
                            value="1"
                            {% if media.type.value == 'portfolio_featured' %}checked{% endif %}
                        >
                        <label for="isFeatured" class="checkbox-label">
                            ★ Mark as Featured Photo
                        </label>
                        <small class="form-help">Featured photos appear in your portfolio showcase on your public profile</small>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="button button--accent button--medium">Save Changes</button>
                        <a href="{{ path('photographer_gallery_edit', { slug: photographer.slug, galleryId: gallery.id }) }}" class="button button--black-variant button--medium">Cancel</a>
                    </div>
                </form>
            </div>
        </div>

    </div>
</section>


{% endblock %}
