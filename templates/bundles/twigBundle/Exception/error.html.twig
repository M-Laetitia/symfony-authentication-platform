
{% extends 'base.html.twig' %}
{% block navbar %}{% endblock %}
{% block footer %}{% endblock %}
{% block title %}404 - Page Not Found | MOSAIC{% endblock %}

{% block body %}
<!-- DEBUG: Template error.html.twig CHARGÉ - status_code={{ status_code }} -->
<style>
.page-wrapper { margin-top: 0 !important; }
</style>

<section class="error-page">
    <div class="error-page__top">
        <div class="error-page__brand">
            <span class="error-page__logo">{% include 'components/icons/logo.html.twig' %}</span>
            <span class="error-page__site-name">MOSAIC</span>
        </div>
    </div>
    <div class="error-page__content">
        <aside class="error-side-panel error-side-panel--left"></aside>
        <section class="error-content">
            <div class="error-content__text">
                <div class="error-code">
                    <h1 class="error-code__number">{{ status_code|default('404') }}</h1>
                </div>
                <h2 class="error-title">{{ title|default('Page Not Found') }}</h2>
                <p class="error-description">{{ description|default("The page you're looking for doesn't exist. It might have been moved or deleted.") }}</p>
                <div class="error-actions">
                    <a href="{{ path('home') }}" class="button button--accent button--large">
                        Back to Home
                    </a>
                </div>
            </div>
            <img src="{{asset('uploads/media/pattern/pattern_footer_1600.webp')}}" alt="" class="error-content__image" aria-hidden="true">
        </section>
        <aside class="error-side-panel error-side-panel--right"></aside>
    </div>
    <div class="error-page__bottom"></div>
</section>
{% endblock %}
