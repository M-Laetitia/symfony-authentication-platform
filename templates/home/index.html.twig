{% extends 'base.html.twig' %}

{% block title %}Home | MOSAIC {% endblock %}

{# {% block preload %}
    <link rel="preload" as="image" href="{{ 'media/hero-image.webp' | imagine_filter('hero_image') }}">
{% endblock %} #}

{% block body %}
    <section class="hero" aria-labelledby="hero-title">
        <div class="hero__container">
            <!-- Left decorative sidebar -->
            <div class="hero__sidebar hero__sidebar--left"></div>

            <!-- Main hero content -->
            <div class="hero__main">
                <figure class="hero__figure">
                    <img 
                        src="{{ 'media/hero-image.webp' | imagine_filter('hero_image') }}"
                        alt="MOSAIC Photography Studio" 
                        class="hero__image u-img-cover"
                        data-parallax
                        loading="eager"
                        width="1360"
                        height="1080"
                    >
                </figure>
                <div class="hero__content">
                    <h1 id="hero-title" class="hero__title">MOSAIC</h1>
                    <p class="hero__subtitle">Capturing your most precious moments with passion and artistry</p>
                    <a href="{{ path('team_index') }}" class="hero__cta">
                         Discover our work   <span>></span>
                    </a>
                </div>
            </div>

            <!-- Right decorative sidebar -->
            <div class="hero__sidebar hero__sidebar--right"></div>
        </div>
    </section>

    <section class="section section-about" aria-labelledby="about-title">
        <div class="scroll-text-section">
            <div class="bg-text--scroll bg-text--about" aria-hidden="true">
                <div class="bg-text__track">
                    <span>ABOUT US</span>
                    <span>ABOUT US</span>
                    <span>ABOUT US</span>
                    <span>ABOUT US</span>
                </div>
            </div>
    
            <div class="section-about__content scroll-text-section__content section-centered">

                <twig:SectionIntro
                    title="ABOUT US"
                    subtitle="photography agency focused on authentic images and natural storytelling."
                    buttonText="Discover more"
                    linkBtn="/team"
                    titleId="about-title"
                />

                <div class="section-about__text-image">
                    <!-- Text -->
                    <div class="section-about__text">
                        <h3 class="section-about__subtitle">A photographic story...</h3>
                        <div class="section-divider__large" aria-hidden="true"></div>
                        <p class="text-medium">
                            Our agency was built around a simple idea: <strong>photography should feel alive</strong> . We work across portrait, lifestyle, nature, and editorial fields, focusing on real emotions rather than staged perfection. Every project is approached as a narrative, where light, composition, and atmosphere come together to reveal something honest and lasting.
                            <br><br>
                            We believe in simplicity, in the strength of subtle gestures, and in the <strong>beauty of everyday moments.</strong>  Whether it is a portrait session, a creative collaboration, or a personal project, our goal is always the same: to create images that <strong>resonate beyond the frame.</strong>
                        </p>
                    </div>
        
                    <!-- Image -->
                    <div class="section-about__image-wrapper">
                        <figure class="section-about__figure">
                            <img 
                                src="{{ 'media/mosaic-polaroids.webp' | imagine_filter('about_image_desktop') }}"
                                srcset="
                                    {{ 'media/mosaic-polaroids.webp' | imagine_filter('about_image_mobile') }} 800w,
                                    {{ 'media/mosaic-polaroids.webp' | imagine_filter('about_image_desktop') }} 365w
                                "
                                sizes="(max-width: 1024px) 800px, 365px"
                                alt="MOSAIC - polaroids photograhies"
                                class="section-about__image u-img-cover"
                                width="365" height="480"
                                loading="lazy"
                            >
                        </figure>
                    </div>
                </div>
        
                <!-- Bloc mission / vision / value -->
                <div class="section-about__features">
                    <div class="section-about__feature icon-box__container">
                        <div class="section-about__feature-icon">
                                <twig:IconBox 
                                    svg='{{ include("components/icons/target.html.twig") }}'
                                />
                        </div>
                        <div class="section-about__feature-text">
                            <h3 class="section-about__feature-title icon-box__link">Our mission</h3>
                            <p class="section-about__feature-description">onnects people through real emotions and honest storytelling.</p>
                        </div>
                    </div>
                    <div class="section-about__feature icon-box__container">
                        <div class="section-about__feature-icon">
                            <twig:IconBox 
                            svg='{{ include("components/icons/camera2.html.twig") }}'
                        />
                        </div>
                        <div class="section-about__feature-text">
                            <h3 class="section-about__feature-title icon-box__link">Our vision</h3>
                            <p class="section-about__feature-description">To keep photography human, expressive, and free supporting strong artistic voices.</p>
                        </div>
                    </div>
                    <div class="section-about__feature icon-box__container">
                        <div class="section-about__feature-icon">
                            <twig:IconBox 
                            svg='{{ include("components/icons/book.html.twig") }}'
                        />
                        </div>
                        <div class="section-about__feature-text">
                            <h3 class="section-about__feature-title icon-box__link">Our value</h3>
                            <p class="section-about__feature-description">We value authenticity, creativity, and care in every image we produce.</p>
                        </div>
                    </div>
                </div>
                
            </div>
    
        </div>

    </section>

    <div class="u-divider-medium"></div>

    <section class="section section-services" aria-labelledby="services-title">
        <div class="scroll-text-section">
            <div class="bg-text--scroll bg-text--services" aria-hidden="true">
                <div class="bg-text__track">
                    <span>SERVICES</span>
                    <span>SERVICES</span>
                    <span>SERVICES</span>
                    <span>SERVICES</span>
                </div>
            </div>

            <div class="section-services__content scroll-text-section__content">

                <twig:SectionIntro
                title="Our services"
                subtitle="Professional photography for creative, and memorable moments."
                buttonText="Discover more"
                linkBtn="#"
                :showButton="false"
                titleId="services-title"
                />
                
                <div class="section-services__list">
                    <!-- item service -->
                    <twig:ServiceBox 
                        title="Wedding session"
                        subtitle="Elegant images capturing love, emotion, and celebration."
                        link="#"
                        imageSrc="uploads/media/wedding_moment.webp"
                    />
                    <twig:ServiceBox 
                        title="Model Photoshoot"
                        subtitle="Creative portraits designed for style and confidence."
                        link="#"
                        imageSrc="uploads/media/model_photoshot.webp"
                    />
                    <twig:ServiceBox 
                        title="Event photography"
                        subtitle="Natural coverage of events, gatherings, and occasions."
                        link="#"
                        imageSrc="uploads/media/concert_photography.webp"
                    />
                    <twig:ServiceBox 
                        title="Portrait session"
                        subtitle="Authentic portraits with a timeless and personal feel."
                        link="#"
                        imageSrc="uploads/media/portrait_session.webp"
                    />
                </div>
    
            </div>
        </div>
    </section>

    <div class="u-divider-medium"></div>

    <section class="section section-dark section-photographs" aria-labelledby="photographs-title">

        <div class="scroll-text-section">
            <div class="bg-text--scroll bg-text--light bg-text--photographs" aria-hidden="true" role="presentation">
                <div class="bg-text__track">
                    <span aria-hidden="true">PHOTOGRAPHERS</span>
                    <span aria-hidden="true">PHOTOGRAPHERS</span>
                    <span aria-hidden="true">PHOTOGRAPHERS</span>
                    <span aria-hidden="true">PHOTOGRAPHERS</span>
                </div>
            </div>

            <twig:SectionIntro
            title="Our photographers"
            subtitle=" A team of photographers with unique perspectives capturing your most precious moments."
            buttonText="Meet the artists"
            linkBtn="/team"
            variant="light"
            titleId="photographs-title"
            />
            <div class="section-photographs__content scroll-text-section__content" >
                <div class="section-photographs__list">
                   <div class="embla" data-controller="carousel">
                        <div class="embla__viewport" data-carousel-target="viewport">
                            <div class="embla__container">

                                {% for photographer in photographers %}
                                    {% set cover = photographer.media|first %}

                                    <div class="embla__slide">
                                        <twig:PhotographBox 
                                            :service="photographer.specialityNames|join(', ')"
                                            :name="photographer.firstName ~ ' ' ~ photographer.lastName"
                                            :slug="photographer.slug"
                                            :alt="cover ? (cover.altText ?: photographer.firstName ~ ' ' ~ photographer.lastName ~ ' featured picture') : photographer.firstName ~ ' ' ~ photographer.lastName ~ ' featured picture'"
                                            :imageSrc="cover ? asset('uploads/' ~ cover.path) : asset('media/images/camera.jpg')"
                                        />
                                    </div>
                                {% endfor %}

                            </div>
                        </div>
                         <div class="carousel-nav section-photographs__carousel-nav">
                    <div class="carousel-nav__arrows">
                        <button
                            class="carousel-nav__arrow embla__prev"
                            type="button"
                            data-action="click->carousel#prev"
                            aria-label="Previous slide"
                        >
                        {% include 'components/icons/leftArrow.html.twig' %}

                        </button>

                        <button
                            class="carousel-nav__arrow embla__next"
                            type="button"
                            data-action="click->carousel#next"
                            aria-label="Next slide"
                        >
                            {% include 'components/icons/rightArrow.html.twig' %}
                        </button>
                    </div>

                    <div
                        class="carousel-nav__dots embla__dots"
                        data-carousel-target="dots"
                        role="tablist"
                        aria-label="Photographer carousel navigation"
                    ></div>
                </div>
            </div>
                    </div> 
                </div>
            </div>
        </div>

    </section>

    <div class="u-divider-medium"></div>

    <section class="section section-works" aria-labelledby="works-title">

        <div class="scroll-text-section">
            <div class="bg-text--scroll  bg-text--works" aria-hidden="true">
                <div class="bg-text__track">
                    <span>LATEST WORKS</span>
                    <span>LATEST WORKS</span>
                    <span>LATEST WORKS</span>
                    <span>LATEST WORKS</span>
                </div>
            </div>

            <twig:SectionIntro
            title="Our lastest works"
            subtitle="Lorem ipsum dolor sit amet, consectetur adipiscing elit."
            buttonText="Explore more"
            linkBtn="/team"
            titleId="works-title"
            />

            <div class="section-works__content scroll-text-section__content">

                <div class="section-works__gallery">
                    {% for portfolio in latestPhotographies %}
                    {% set isLandscape = loop.first or loop.last %}
                    <figure class="gallery__item {% if isLandscape %}gallery__item--landscape{% else %}gallery__item--portrait{% endif %}">
                        <a href="{{ path('team_show', { 'slug': portfolio.photographer.slug }) }}"><img class="gallery__image u-img-cover" src="{{ portfolio.path | imagine_filter(isLandscape ? 'works_thumb_landscape' : 'works_thumb_portrait') }}" alt="{{ portfolio.title }}" width="{{ isLandscape ? 880 : 370 }}" height="{{ isLandscape ? 600 : 500 }}" loading="lazy">
                        <div class="gallery__detail">
                            <div  class="gallery__detail-link">
                                <div class="gallery__detail-content">
                                    <span class="gallery__name">{{ portfolio.photographer.firstName }} {{ portfolio.photographer.lastName }}</span>
                                    <span class="separator" aria-hidden="true"></span>
                                    <span class="gallery__service">{{ portfolio.gallerySeries.name }}</span>
                                </div>
                            </div>
                        </div></a>
                    </figure>
                    {% endfor %}
                </div>

            </div>
        </div>

    </section>

    <div class="u-divider-medium"></div>

    <section class="section section-testimonials " aria-labelledby="testimonials-title">
        <div class="scroll-text-section">
            <div class="bg-text--scroll bg-text--testimonials" aria-hidden="true">
                <div class="bg-text__track">
                    <span>TESTIMONIALS</span>
                    <span>TESTIMONIALS</span>
                    <span>TESTIMONIALS</span>
                    <span>TESTIMONIALS</span>
                </div>
            </div>
    
            <div class="section-testimonials__content scroll-text-section__content section-centered">

                <twig:SectionIntro
                title="Testimonials"
                subtitle="Words from those who trusted us with their stories."
                buttonText="Discover more"
                linkBtn="#"
                :showButton="false"
                titleId="testimonials-title"
                />

                <div class="section-testimonials__container">
                    <twig:TestimonialBox
                    content="Working with this agency was a smooth and inspiring experience from start to finish. The photographer made us feel comfortable immediately and captured natural moments with great sensitivity. Every image felt elegant, authentic, and full of emotion. The final gallery exceeded our expectations and gave us memories we will keep for years. Their professionalism, creativity, and attention to detail were remarkable throughout the entire session."
                    subtitle="Great memories captured for our wedding"
                    username="Emma Laurent"
                    />

                    <twig:TestimonialBox
                    content="I booked a portrait session for my personal brand and was impressed by the quality of the experience. The direction was clear, relaxed, and confidence-building, which made the shoot feel effortless. The photographs were refined, modern, and exactly aligned with what I needed. Communication was excellent, delivery was fast, and the final result was outstanding in every way."
                    subtitle="Strong personal branding portraits"
                    username="Clara Moreau"
                    />
                </div>
            </div>
        </div>
    </section>

    <div class="u-divider-medium"></div>


    {% include 'layout/contact.html.twig' %} 


    <div class="u-divider-medium"></div>

    <section class="section section-articles " aria-labelledby="articles-title">
        <div class="scroll-text-section">
            <div class="bg-text--scroll bg-text--articles" aria-hidden="true">
                <div class="bg-text__track">
                    <span>ARTICLES</span>
                    <span>ARTICLES</span>
                    <span>ARTICLES</span>
                    <span>ARTICLES</span>
                </div>
            </div>
    
            <div class="section-articles__content scroll-text-section__content section-centered">

                <twig:SectionIntro
                title="Articles & blog"
                subtitle="Insights, stories, and inspiration from our photographic work and creative projects."
                buttonText="Discover our blog"
                linkBtn="/blog"
                />

                <div class="section-articles__container">

                    {% if latestArticles is not empty %}
                    <section class="related-articles section-centered">
                       
                        <div class="related-articles__list">
                            {% for article in latestArticles %}
                            {% set cover = article.medias|first %}
                                    <twig:ArticleBox
                                    :title="article.title"
                                    :imagePath="cover ? cover.path : ''"
                                    :slug="article.slug"
                                    :date="article.createdAt|date('j F Y')"
                                    :tags="article.tags is defined ? article.tags|map(t => t.name) : []"
                                    />
                            {% endfor %}
                        </div>

                    </section>
                    {% endif %}

                </div>
            </div>
        </div>
    </section>

    <div class="u-divider-large"></div>


    {% include 'layout/subscribe.html.twig' %}


{% endblock %}