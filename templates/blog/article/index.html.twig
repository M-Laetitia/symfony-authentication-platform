{% extends 'base.html.twig' %}

{% block title %}Photography Tips &amp; Inspiration | Blog{% endblock %}

{% block body %}

<twig:Banner
    title="Discover, Create & Inspire"
    subtitle="See the World Through the Lens"
    :breadcrumbs="[
        { label: 'Home', url: path('home'), type: 'link' },
        { label: 'separator', type: 'separator' },
        { label: 'Blog', type: 'current' }
    ]"
    id="blog-title"
/>
{# Capture. Create. Inspire. #}
{# Explore articles, ideas, and inspiration. #}

<section
    class="main-section-page blog u-display-center"
    aria-labelledby="blog-title"
>
    <div class="blog__wrapper section-centered">

        <aside class="blog__aside" aria-label="blog sidebar">
            {% include 'blog/article/_aside.html.twig' %}
        </aside>
    
        <div class="blog__content">

            {% for article in pagination %}

                {% set cover = article.medias|first %}
                <twig:ArticleBlogBox
                    :title="article.title"
                    :slug="article.slug"
                    :imagePath="cover ? cover.path : ''"
                    :tags="article.tags is defined ? article.tags|map(t => t.name) : []"
                    :date="article.createdAt|date('j F Y')"
                    :excerpt="article.excerpt ?? ''"
                    :alt="cover ? cover.altText : article.title"
                />
            {% else %}
                <p>No articles found.</p>
            {% endfor %}

            <div class="blog__footer">

                <div class="blog__pagination">
                    {{ knp_pagination_render(pagination) }}
                </div>

                {% if app.user and (is_granted('ROLE_ADMIN') or is_granted('ROLE_PHOTOGRAPHER')) %}
                    <div class="blog__actions">
                        <a href="{{ path('article_new') }}" class="blog__button-link">
                            <button type="button" class="button button--medium button--accent blog__button">New article</button>
                        </a>
                    </div>
                {% endif %}

            </div>

        </div>

    </div>

</section>




{% endblock %}