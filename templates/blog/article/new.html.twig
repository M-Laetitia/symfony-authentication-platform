
{% extends 'base.html.twig' %}

{% block title %}{% if isEdit is defined and isEdit %}Edit Article{% else %}Create Article{% endif %}{% endblock %}

{% block body %}

<div class="admin-page admin-article-form">
    <div class="admin-article-form__header">
        <h1 class="admin-article-form__title">
            {% if isEdit is defined and isEdit %}Edit Article{% else %}Create Article{% endif %}
        </h1>
    </div>

    {{ form_start(form, {'attr': {'class': 'admin-article-form__form'}}) }}

    <!-- Basic Information Section -->
    <section class="admin-article-form__section admin-article-form__section--basic">
        <h2 class="admin-article-form__section-title">Basic Information</h2>
        
        <div class="admin-article-form__field">
            {{ form_label(form.title) }}
            {{ form_widget(form.title) }}
            {{ form_errors(form.title) }}
        </div>

        <div class="admin-article-form__field">
            {{ form_label(form.introduction) }}
            {{ form_widget(form.introduction) }}
            {{ form_errors(form.introduction) }}
        </div>

        <div class="admin-article-form__field">
            {{ form_label(form.excerpt) }}
            {{ form_widget(form.excerpt) }}
            {{ form_errors(form.excerpt) }}
        </div>
    </section>

    <!-- SEO Section -->
    <section class="admin-article-form__section admin-article-form__section--seo">
        <h2 class="admin-article-form__section-title">SEO</h2>
        
        <div class="admin-article-form__field">
            {{ form_label(form.metaTitle) }}
            {{ form_widget(form.metaTitle) }}
            {{ form_errors(form.metaTitle) }}
        </div>

        <div class="admin-article-form__field">
            {{ form_label(form.metaDescription) }}
            {{ form_widget(form.metaDescription) }}
            {{ form_errors(form.metaDescription) }}
        </div>
    </section>

    <!-- Categories & Tags Section -->
    <section class="admin-article-form__section admin-article-form__section--taxonomy">
        <h2 class="admin-article-form__section-title">Categories & Tags</h2>
        
        <div class="admin-article-form__field taxonomy-field">
            {{ form_label(form.category) }}
            {{ form_widget(form.category) }}
            {{ form_errors(form.category) }}
        </div>

        <fieldset class="admin-article-form__field admin-article-form__field--tags">
            <legend class="admin-article-form__label">
                {{ form_label(form.tags) }}
            </legend>

            {{ form_widget(form.tags) }}
            {{ form_errors(form.tags) }}
        </fieldset>
    </section>

    <!-- Cover Image Section -->
    <section class="admin-article-form__section admin-article-form__section--cover">
        <h2 class="admin-article-form__section-title">Cover Image</h2>
        
        <div class="admin-article-form__field">
            {{ form_label(form.coverFile) }}
            {{ form_widget(form.coverFile) }}
            {{ form_errors(form.coverFile) }}
        </div>

        <div class="admin-article-form__field">
            {{ form_label(form.coverAlt) }}
            {{ form_widget(form.coverAlt) }}
            {{ form_errors(form.coverAlt) }}
        </div>
    </section>

    <!-- Options Section -->
    <section class="admin-article-form__section admin-article-form__section--options">
        <h2 class="admin-article-form__section-title">Options</h2>
        
        <div class="admin-article-form__field admin-article-form__field--checkbox">
            {{ form_label(form.isFeatured) }}
            {{ form_widget(form.isFeatured) }}
            {{ form_errors(form.isFeatured) }}
        </div>

        <div class="admin-article-form__field">
            {{ form_label(form.status) }}
            {{ form_widget(form.status) }}
            {{ form_errors(form.status) }}
        </div>
    </section>

    <!-- Content Section -->
    <section class="admin-article-form__section admin-article-form__section--content">
        <h2 class="admin-article-form__section-title">Article Content</h2>
        
        <div class="admin-article-form__field admin-article-form__field--editor">
            <div id="editorjs" class="admin-article-form__editor"></div>
            {{ form_widget(form.content, {'attr': {'id': 'article_content'}}) }}
            {{ form_errors(form.content) }}
        </div>
    </section>

    <!-- Form Actions -->
    <div class="admin-article-form__actions">
        {{ form_row(form.submit, {'attr': {'class': 'button button--accent button--small'}}) }}
        <a href="{{ path('admin_blog_index') }}" class="button button--small button--black">Back to Blog Dashboard</a>
    </div>

    {{ form_end(form) }}

    <!-- Pass existing content to EditorJS -->
    {% if article.content is not null %}
    <script>
        window.articleContent = {{ article.content|json_encode|raw }};
    </script>
    {% endif %}

    {{ encore_entry_script_tags('editor') }}

</div>

{% endblock %}
