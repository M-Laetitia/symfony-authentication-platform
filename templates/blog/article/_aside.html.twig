
<!-- Search bar -->
<div class="search-bar blog__search">
    {{ form_start(searchForm) }}
    <div class="search-bar__input-group">
        <button
        type="submit"
        class="search-bar__button"
        >
        <svg id="fi_7535830" enable-background="new 0 0 24 24" height="30" viewBox="0 0 24 24" width="30" xmlns="http://www.w3.org/2000/svg"><path d="m20.7 19.3-3.4-3.4c1.1-1.4 1.7-3.1 1.7-4.9 0-4.4-3.6-8-8-8s-8 3.6-8 8 3.6 8 8 8c1.8 0 3.5-.6 4.9-1.7l3.4 3.4c.4.4 1 .4 1.4 0 .4-.4.4-1 0-1.4zm-15.7-8.3c0-3.3 2.7-6 6-6s6 2.7 6 6-2.7 6-6 6-6-2.7-6-6z" fill="#F2F2F2"></path></svg>
    </button>
        {{ form_label(searchForm.search, null, { label_attr: { class: 'sr-only' } }) }}
        {{ form_widget(searchForm.search) }}            
    </div>
    

    {% if search %}
        <a href="{{ path('blog_index') }}"
        class="search-bar__clear"
        aria-label="Clear search">
            ↺
        </a>
    {% endif %}
    
    {{ form_rest(searchForm) }}
    {{ form_end(searchForm) }}
</div>      


<!-- Categories -->
<nav class="blog__categories" aria-labelledby="blog-categories-title">
    <h3 id="blog-categories-title" class="blog__title">Categories</h3>

    <ul class="blog__categories-list">
        <!-- Link for all articles -->
        <div class="blog__category-all">
            <a href="{{ path('blog_index') }}" 
               class="blog__category-link {% if not selectedCategory %}active{% endif %}">
                ALL ARTICLES
            </a>
        </div>

        {% for category in categories %}
            <li class="blog__category-item">
                <a href="{{ path('blog_index', { category: category.slug }) }}" 
               class="blog__category-link {% if selectedCategory and selectedCategory.id == category.id %}active{% endif %}">
                {{ category.name }}
                <span class="category-count">({{ category.articlesCount }})</span>
            </a>
            </li>
        {% endfor %}
    </ul>
</nav>

<!-- Top posts -->
<section class="blog__top-posts" aria-labelledby="blog-top-posts-title">
    <h3 id="blog-top-posts-title" class="blog__title">Featured posts</h3>
    <ol class="blog__top-posts-list">
        {% for article in topArticles %}
            <li class="blog__top-post">
                <span class="blog__top-post-rank">{{ loop.index }}</span>
                <article class="blog__top-post-content">
                <h4>
                    <a href="{{ path('article_show', {'slug': article.slug}) }}" class="blog__top-post-link">
                    {{ article.title }}
                    </a>
                </h4>
                        
                    <div class="blog__top-post-tags">
                        {% if article.tags|length %}
                            <small>
                                {% for tag in article.tags %}
                                    <span class="blog__tag">{{ tag.name }}{% if not loop.last %} {% endif %}</span>
                                {% endfor %}
                            </small>
                        {% endif %}
                    </div>
                </article>
            </li>
        {% endfor %}
    </ol>
</section>

