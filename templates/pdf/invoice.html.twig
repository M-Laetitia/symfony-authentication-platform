<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: Arial, sans-serif;
            font-size: 13px;
            color: #333;
            padding: 40px;
        }

        /* ── HEADER ── */
        .header {
            display: table;
            width: 100%;
            margin-bottom: 40px;
        }
        .header-left, .header-right {
            display: table-cell;
            width: 50%;
            vertical-align: top;
        }
        .header-right { text-align: right; }

        .invoice-title {
            font-size: 26px;
            font-weight: bold;
            color: #1a1a1a;
            margin-bottom: 4px;
        }
        .invoice-number { font-size: 14px; color: #666; }
        .invoice-date   { font-size: 13px; color: #666; margin-top: 4px; }

        .badge-paid {
            display: inline-block;
            background-color: #22c561;
            color: white;
            padding: 4px 12px;
            border-radius: 4px;
            font-size: 12px;
            font-weight: bold;
            margin-top: 8px;
        }

        /* ── PARTIES ── */
        .parties-table {
            width: 100%;
            margin-bottom: 36px;
        }
        .party {
            width: 48%;
            background: #f9f9f9;
            border: 1px solid #e5e5e5;
            padding: 16px;
            vertical-align: top;
        }
        .party-spacer {
            width: 4%;
        }
        .party-label {
            font-size: 11px;
            text-transform: uppercase;
            color: #999;
            letter-spacing: 1px;
            margin-bottom: 8px;
        }
        .party-name {
            font-size: 15px;
            font-weight: bold;
            margin-bottom: 4px;
        }
        .party p { line-height: 1.6; color: #555; }

        /* ── TABLEAU PRESTATION ── */
        table.items {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 24px;
        }
        table.items thead tr {
            background-color: #1a1a1a;
            color: white;
        }
        table.items thead th {
            color: white;
        }
        table.items th {
            padding: 10px 12px;
            text-align: left;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        table.items td {
            padding: 12px;
            border-bottom: 1px solid #e5e5e5;
        }
        table.items tr:last-child td { border-bottom: none; }
        .text-right { text-align: right; }

        /* ── TOTAL ── */
        .total-block {
            width: 260px;
            margin-left: auto;
            margin-bottom: 36px;
        }
        .total-row {
            display: table;
            width: 100%;
            padding: 6px 0;
            border-bottom: 1px solid #e5e5e5;
        }
        .total-row:last-child { border-bottom: none; }
        .total-label, .total-value {
            display: table-cell;
        }
        .total-value { text-align: right; }
        .total-final {
            font-size: 16px;
            font-weight: bold;
            color: #1a1a1a;
        }
        .tva-mention {
            font-size: 11px;
            color: #999;
            text-align: right;
            margin-top: 4px;
        }

        /* ── PAIEMENT ── */
        .payment-block {
            background: #f0fdf4;
            border: 1px solid #bbf7d0;
            padding: 14px 16px;
            margin-bottom: 36px;
        }
        .payment-block .payment-title {
            font-weight: bold;
            color: #15803d;
            margin-bottom: 8px;
        }
        .payment-block p { color: #555; line-height: 1.7; }
        .transaction-id { font-size: 11px; color: #999; margin-top: 4px; }

        /* ── FOOTER ── */
        .footer {
            border-top: 1px solid #e5e5e5;
            padding-top: 16px;
            font-size: 11px;
            color: #999;
            text-align: center;
            line-height: 1.8;
        }
    </style>
</head>
<body>

    {# ── HEADER ── #}
    <div class="header">
        <div class="header-left">
            <div class="invoice-title">Facture</div>
            <div class="invoice-number">N° {{ invoice_number }}</div>
            <div class="invoice-date">Émise le {{ issued_at }}</div>
            <div class="badge-paid">✓ Payée</div>
        </div>
        <div class="header-right">
            {# Logo éventuel plus tard #}
        </div>
    </div>

    {# ── VENDEUR / ACHETEUR ── #}
    <table class="parties-table" cellpadding="0" cellspacing="0">
        <tr>
            <td class="party">
                <div class="party-label">Prestataire</div>
                <div class="party-name">{{ seller.firstName }} {{ seller.lastName }}</div>
                <p>
                {{ seller.address }}<br>
                {{ seller.postal_code }} {{ seller.city }}<br>
                SIRET : {{ seller.siret }}<br>
                {# {% if seller.vat_number is defined and seller.vat_number %}
                    TVA : {{ seller.vat_number }}
                {% else %}
                    TVA non applicable, art. 293B du CGI
                {% endif %} #}
            </p>
        </td>
        <td class="party-spacer"></td>
        <td class="party">
            <div class="party-label">Client</div>
            <div class="party-name">{{ buyer.name }}</div>
            <p>
                {{ buyer.line1 }}<br>
                {% if buyer.line2 %}{{ buyer.line2 }}<br>{% endif %}
                {{ buyer.postal_code }} {{ buyer.city }}<br>
                {{ buyer.country }}<br>
                {{ buyer.email }}
            </p>
        </td>
    </tr>
</table>

    {# ── PRESTATION ── #}
    <table class="items">
        <thead>
            <tr>
                <th>Description</th>
                <th>Date de prestation</th>
                <th class="text-right">Montant HT</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>{{ description }}</td>
                {# <td>{{ service_date }}</td> #}
                <td class="text-right">{{ amount_ht }} €</td>
            </tr>
        </tbody>
    </table>

    {# ── TOTAL ── #}
    <div class="total-block">
        <div class="total-row">
            <span class="total-label">Sous-total HT</span>
            <span class="total-value">{{ amount_ht }} €</span>
        </div>
        <div class="total-row">
            <span class="total-label">TVA : {{ tax }} </span>
            <span class="total-value">{{ amount_tax }}</span>
        </div>
        <div class="total-row">
            <span class="total-label total-final">Total TTC</span>
            <span class="total-value total-final">{{ amount_ttc }} €</span>
        </div>
        {# <p class="tva-mention">TVA non applicable, art. 293B du CGI</p> #}
    </div>

    {# ── PAIEMENT ── #}
    <div class="payment-block">
        <div class="payment-title">Paiement reçu</div>
        <p>
            Mode de paiement : {{ payment_method }}<br>
            Date de paiement : {{ paid_at }}<br>
            Montant réglé : {{ amount_ttc }} €
        </p>
        {# <p class="transaction-id">Référence transaction : {{ transaction_id }}</p> #}
    </div>

    {# ── FOOTER ── #}
    <div class="footer">
        <p>{{ seller.firstName }} {{ seller.lastName }} — SIRET {{ seller.siret }}</p>
        <p>Cette facture tient lieu de reçu. Paiement effectué et confirmé.</p>
    </div>

</body>
</html>