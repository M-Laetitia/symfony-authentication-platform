<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: Arial, sans-serif;
            font-size: 13px;
            color: #333;
            padding: 40px;
        }

        /* ── HEADER ── */
        .header {
            display: table;
            width: 100%;
            margin-bottom: 40px;
        }
        .header-left, .header-right {
            display: table-cell;
            width: 50%;
            vertical-align: top;
        }
        .header-right { text-align: right; }

        .invoice-title {
            font-size: 26px;
            font-weight: bold;
            color: #1a1a1a;
            margin-bottom: 4px;
        }
        .invoice-number { font-size: 14px; color: #666; }
        .invoice-date   { font-size: 13px; color: #666; margin-top: 4px; }

        .badge-paid {
            display: inline-block;
            background-color: #22c561;
            color: white;
            padding: 4px 12px;
            border-radius: 4px;
            font-size: 12px;
            font-weight: bold;
            margin-top: 8px;
        }

        /* ── PARTIES ── */
        .parties-table {
            width: 100%;
            margin-bottom: 36px;
        }
        .party {
            width: 48%;
            background: #f9f9f9;
            border: 1px solid #e5e5e5;
            padding: 16px;
            vertical-align: top;
        }
        .party-spacer {
            width: 4%;
        }
        .party-label {
            font-size: 11px;
            text-transform: uppercase;
            color: #999;
            letter-spacing: 1px;
            margin-bottom: 8px;
        }
        .party-name {
            font-size: 15px;
            font-weight: bold;
            margin-bottom: 4px;
        }
        .party p { line-height: 1.6; color: #555; }

        /* ── TABLEAU PRESTATION ── */
        table.items {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 24px;
        }
        table.items thead tr {
            background-color: #1a1a1a;
            color: white;
        }
        table.items thead th {
            color: white;
        }
        table.items th {
            padding: 10px 12px;
            text-align: left;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        table.items td {
            padding: 12px;
            border-bottom: 1px solid #e5e5e5;
        }
        table.items tr:last-child td { border-bottom: none; }
        .text-right { text-align: right; }

        /* ── TOTAL ── */
        .total-block {
            width: 260px;
            margin-left: auto;
            margin-bottom: 36px;
        }
        .total-row {
            display: table;
            width: 100%;
            padding: 6px 0;
            border-bottom: 1px solid #e5e5e5;
        }
        .total-row:last-child { border-bottom: none; }
        .total-label, .total-value {
            display: table-cell;
        }
        .total-value { text-align: right; }
        .total-final {
            font-size: 16px;
            font-weight: bold;
            color: #1a1a1a;
        }
        .tva-mention {
            font-size: 11px;
            color: #999;
            text-align: right;
            margin-top: 4px;
        }

        /* ── PAIEMENT ── */
        .payment-block {
            background: #f0fdf4;
            border: 1px solid #bbf7d0;
            padding: 14px 16px;
            margin-bottom: 36px;
        }
        .payment-block .payment-title {
            font-weight: bold;
            color: #15803d;
            margin-bottom: 8px;
        }
        .payment-block p { color: #555; line-height: 1.7; }
        .transaction-id { font-size: 11px; color: #999; margin-top: 4px; }

        /* ── FOOTER ── */
        .footer {
            border-top: 1px solid #e5e5e5;
            padding-top: 16px;
            font-size: 11px;
            color: #999;
            text-align: center;
            line-height: 1.8;
        }
    </style>
</head>
<body>

    {# ── HEADER ── #}
    <div class="header">
        <div class="header-left">
            <div class="invoice-title">Facture</div>
            <div class="invoice-number">N° {{ invoice_number }}</div>
            {# <div class="invoice-date">Émise le {{ issued_at }}</div> #}
            <div class="badge-paid">✓ Payée</div>
        </div>
        <div class="header-right">
            {# Logo éventuel plus tard #}
        </div>
    </div>


</body>
</html>
